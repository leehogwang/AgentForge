        except Exception:
            pass
    vec = _embed_goal(goal_text)
    if vec is not None:
        try:
            np.save(str(emb_path), vec)
        except Exception:
            pass
    return vec


def _find_similar_goals(goal: str, threshold: float = 0.6) -> list[Path]:
    """
    KNOWLEDGE_DIR 내 모든 폴더와 유사도 비교.
    - 임베딩 사용 가능: cosine similarity (goal_embedding.npy)
    - 불가능: 토큰 recall 폴백
    임계값 이상인 폴더 목록 반환 (현재 goal 폴더 제외).
    """
    if not KNOWLEDGE_DIR.exists():
        return []

    current_slug = _goal_to_slug(goal)
    use_embedding = _get_embed_model() is not None
    current_vec = _embed_goal(goal) if use_embedding else None

    matched = []
    for d in KNOWLEDGE_DIR.iterdir():
        if not d.is_dir() or d.name == current_slug:
            continue
        candidate_text = _ensure_goal_txt(d)
        if use_embedding and current_vec is not None:
            cand_vec = _ensure_goal_embedding(d, candidate_text)
            if cand_vec is not None:
                sim = _cosine_sim(current_vec, cand_vec)
            else:
                sim = _goal_similarity_fallback(goal, candidate_text)
        else:
            sim = _goal_similarity_fallback(goal, candidate_text)
        if sim >= threshold:
            matched.append((sim, d))

    matched.sort(key=lambda x: x[0], reverse=True)
    return [d for _, d in matched]


def _load_attempts_from_dir(d: Path) -> list[dict]:
    """디렉토리에서 attempts.jsonl 로드."""
    try:
        path = d / "attempts.jsonl"
        if not path.exists():
            return []
        records = []
        for line in path.read_text(encoding="utf-8").splitlines():
            line = line.strip()
            if line:
                try:
                    records.append(json.loads(line))
                except Exception:
                    pass
        return records
    except Exception:
        return []


def _load_past_attempts(goal: str) -> list[dict]:
    """
    과거 시도 기록 로드.
    1) 현재 goal 폴더 exact match
    2) 유사 goal 폴더들 (Jaccard >= 0.6) 도 합산
    """
    # 현재 goal의 폴더에 goal.txt + 임베딩 저장 (향후 유사도 비교용)
    try:
        gdir = _knowledge_path(goal)
        gtxt = gdir / "goal.txt"
        if not gtxt.exists():
            gtxt.write_text(goal, encoding="utf-8")
        _ensure_goal_embedding(gdir, goal)
    except Exception:
        pass

    records = _load_attempts_from_dir(_knowledge_path(goal))

    # 유사 goal 폴더 병합
    similar_dirs = _find_similar_goals(goal, threshold=0.6)
    seen_dirs = {_goal_to_slug(goal)}
    for d in similar_dirs:
        if d.name not in seen_dirs:
            seen_dirs.add(d.name)
            records += _load_attempts_from_dir(d)

    return records


def _retrieve_relevant(query: str, attempts: list[dict], top_k: int = 6) -> list[dict]:
    """
    BM25로 query와 가장 관련 있는 과거 시도 검색.
    rank_bm25 없으면 단어 overlap 기반 폴백.
    """
    if not attempts:
        return []

    def _text(a: dict) -> str:
        return f"{a.get('feedback','')} {a.get('worker_summary','')} {a.get('decision','')}"

    try:
        from rank_bm25 import BM25Okapi
        corpus = [_text(a).lower().split() for a in attempts]
        bm25 = BM25Okapi(corpus)
        scores = bm25.get_scores(query.lower().split())
        top_idx = sorted(range(len(scores)), key=lambda i: scores[i], reverse=True)[:top_k]
        return [attempts[i] for i in top_idx]
    except Exception:
        # 폴백: 단어 overlap 점수
        q_words = set(query.lower().split())
        scored = []
        for a in attempts:
            words = set(_text(a).lower().split())
            scored.append((len(q_words & words), a))
        scored.sort(key=lambda x: x[0], reverse=True)
        return [a for _, a in scored[:top_k]]


def _build_rag_section(past_attempts: list[dict], current_context: str) -> str:
    """
    현재 상황과 관련된 과거 시도를 RAG로 검색하여
    Worker 프롬프트에 삽입할 경고 섹션 생성.
    """
    if not past_attempts:
        return ""

    MAX_FULL = 50
    if len(past_attempts) <= MAX_FULL:
        relevant = past_attempts
    else:
        relevant = _retrieve_relevant(current_context, past_attempts, top_k=50)
    if not relevant:
        return ""

    lines = [
        "━" * 60,
        "PAST ATTEMPTS FROM PREVIOUS SESSIONS — DO NOT REPEAT THESE:",
    ]
    for a in relevant:
        decision = a.get("decision", "?")
        feedback = a.get("feedback", "")[:200]
        summary  = a.get("worker_summary", "")[:150]
        ts       = a.get("timestamp", "")[:10]
        badge    = {"DONE": "✓", "IMPROVE": "▲", "REDIRECT": "↩"}.get(decision, "?")
        lines.append(f"  [{badge} {decision}] ({ts}) {feedback}")
        if summary:
            lines.append(f"    tried: {summary}")
        hyp = a.get("hypothesis", "")
        if hyp:
            lines.append(f"    hypothesis was: {hyp}")
    lines.append("━" * 60)
    return "\n".join(lines)


def _extract_hypothesis(text: str) -> str:
    m = _HYPOTHESIS_RE.search(text)
    return m.group(1).strip()[:200] if m else ""


def _write_report_entry(goal: str, iteration: int, decision: str,
