_EMBED_MODEL = None
_EMBED_MODEL_NAME = "paraphrase-multilingual-MiniLM-L12-v2"

def _get_embed_model():
    """sentence-transformers 모델 lazy 로드 (최초 1회만)."""
    global _EMBED_MODEL
    if _EMBED_MODEL is None:
        try:
            import warnings
            warnings.filterwarnings("ignore", category=FutureWarning)
            from sentence_transformers import SentenceTransformer
            _EMBED_MODEL = SentenceTransformer(_EMBED_MODEL_NAME)
        except Exception:
            _EMBED_MODEL = False  # 실패 시 폴백 표시
    return _EMBED_MODEL if _EMBED_MODEL is not False else None


def _embed_goal(text: str):
    """goal 텍스트 임베딩 벡터 반환. 모델 없으면 None."""
    model = _get_embed_model()
    if model is None:
        return None
    try:
        import numpy as np
        vec = model.encode(text, normalize_embeddings=True)
        return vec.astype(np.float32)
    except Exception:
        return None


def _cosine_sim(a, b) -> float:
    """두 정규화된 벡터의 cosine similarity (내적)."""
    try:
        import numpy as np
        return float(np.dot(a, b))
    except Exception:
        return 0.0


def _goal_similarity_fallback(a: str, b: str) -> float:
    """임베딩 불가 시 토큰 recall 폴백."""
    def tokens(s: str) -> set:
        return set(re.sub(r'[^\w가-힣]', ' ', s.lower()).split())
    ta, tb = tokens(a), tokens(b)
    if not ta or not tb:
        return 0.0
    shorter, longer = (ta, tb) if len(ta) <= len(tb) else (tb, ta)
    return len(shorter & longer) / len(shorter)


