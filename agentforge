#!/usr/bin/env python3
"""
codex_multi — Worker + Evaluator 인터랙티브 멀티에이전트 CLI

Usage:
  codex_multi [-d DIR] [--worker-model M] [--eval-model M]

Slash commands:
  /exit      종료
  /plan <목표>  계획 수립 후 실행
  <일반 텍스트>  Worker에게 즉시 전달 (목표 설정)
"""

import argparse
import re
import subprocess
import sys
import tempfile
import textwrap
import threading
import time
from collections import deque
from pathlib import Path

from rich.console import Console
from rich.layout import Layout
from rich.live import Live
from rich.panel import Panel
from rich.rule import Rule
from rich.text import Text
