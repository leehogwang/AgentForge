import shlex as _shlex
import shutil as _shutil

TMUX_SESSION = "agentforge"


def _in_tmux() -> bool:
    return bool(os.environ.get("TMUX"))


def _tmux_session_exists() -> bool:
    r = subprocess.run(["tmux", "has-session", "-t", TMUX_SESSION],
                       capture_output=True)
    return r.returncode == 0


def _tmux_launch(extra_args: list):
    """현재 프로세스를 tmux 세션 안의 agentforge로 교체."""
    if _tmux_session_exists():
        console.print(
            f"[yellow]이미 실행 중인 agentforge 세션이 있습니다.[/yellow]\n"
            f"  재접속:  [cyan]agentforge -r[/cyan]\n"
            f"  새 세션: [cyan]agentforge --new-session[/cyan]"
        )
        sys.exit(0)

    exe = _shutil.which("agentforge") or os.path.abspath(sys.argv[0])
    cmd_str = " ".join(_shlex.quote(p) for p in [exe] + extra_args)
    try:
        os.execvp("tmux", ["tmux", "new-session", "-s", TMUX_SESSION, cmd_str])
    except OSError:
        pass  # tmux 실행 실패 → 그냥 일반 모드로 계속


def _tmux_reconnect():
    """기존 agentforge tmux 세션에 재접속."""
    if not _shutil.which("tmux"):
        console.print("[red]tmux가 설치되지 않았습니다.[/red]")
        sys.exit(1)
    if not _tmux_session_exists():
        console.print(
            "[yellow]실행 중인 agentforge 세션이 없습니다.[/yellow]\n"
            "새 세션 시작: [cyan]agentforge[/cyan]"
        )
        sys.exit(1)
    os.execvp("tmux", ["tmux", "attach-session", "-t", TMUX_SESSION])


# ── Agent Loop ────────────────────────────────────────────────────────────────

def run_agent_loop(goal: str, workdir: str, worker_model: str | None,
                   eval_model: str | None, max_iter: int,
                   layout: Layout, live: Live,
                   initial_history: list | None = None,
                   initial_eval_history: list | None = None,
                   mode: str = "code",
                   eval_every: int = 1) -> str:
    """
    Worker + Evaluator 반복 루프.
    반환: 'done' | 'max' | 'interrupted'
    """
    global _last_session
    history = list(initial_history or [])
    eval_history = list(initial_eval_history or [])
    worker_buf = deque(maxlen=WORKER_BUF_LINES)
    worker_status = ["idle"]
    done = False

    # 모드별 시스템 프롬프트 및 도구 선택
    worker_sys   = RESEARCH_WORKER_SYSTEM if mode == "research" else WORKER_SYSTEM
    eval_sys     = RESEARCH_EVALUATOR_SYSTEM if mode == "research" else EVALUATOR_SYSTEM
    active_tools = RESEARCH_TOOLS if mode == "research" else WORKER_TOOLS

    # 압축 상태 — 백그라운드 압축 스레드 결과 수신용
    _compress_result: list[list] = []   # [new_history] 채워지면 완료
    _compress_thread: threading.Thread | None = None

    # ── 지식 저장소 로드 ─────────────────────────────────────────────────
    past_attempts = _load_past_attempts(goal)
    knowledge_dir = _knowledge_path(goal)
    if past_attempts:
        console.print(
            f"[dim]📚 지식 저장소 로드: {knowledge_dir.name}/ "
            f"({len(past_attempts)}개 과거 시도)[/dim]"
        )

    # ESC 리스너 시작
    _interrupt_event.clear()
    _esc_stop = threading.Event()
    esc_t = threading.Thread(target=_esc_listener, args=(_esc_stop,), daemon=True)
    esc_t.start()

    def _finish(result: str) -> str:
        _esc_stop.set()
        return result

    def refresh(phase: str, iteration: int):
        layout["header"].update(render_header(goal, iteration, max_iter, phase))
        layout["worker"].update(render_worker_panel(
            worker_buf, iteration, worker_status[0], history, done))
        layout["evaluator"].update(render_evaluator_panel(
            eval_history, iteration, phase, done))

    for iteration in range(1, max_iter + 1):
        # ── Worker ──────────────────────────────────────────────────────
        worker_buf.clear()
        worker_status[0] = "running"
        if not live._started:
            live.start()
        refresh("worker", iteration)

        worker_prompt = build_worker_prompt(goal, history, past_attempts=past_attempts)
        worker_result = [None, None]

        def _worker():
            worker_result[0], worker_result[1] = run_worker(
                worker_prompt, workdir, worker_model, worker_buf, worker_status,
                system_prompt=worker_sys, tools=active_tools)

        t = threading.Thread(target=_worker, daemon=True)
        t.start()
        while t.is_alive():
            if _interrupt_event.is_set():
                break  # worker 스레드는 _interrupt_event 확인 후 자체 중단
            refresh("worker", iteration)
            time.sleep(0.1)
        t.join(timeout=10)  # 최대 10초 대기 후 포기
        refresh("worker", iteration)

        # ESC로 중단된 경우
        if _interrupt_event.is_set():
            live.stop()
            _last_session = {"goal": goal, "history": history,
                             "eval_history": eval_history, "workdir": workdir}
            _persist_session(_last_session)
            return _finish('interrupted')

        last_msg, _ = worker_result
        worker_summary = (last_msg or "").replace('\n', ' ')[:300]
        history.append({
            'iter': iteration,
            'worker_summary': worker_summary,
            'worker_lines': list(worker_buf)[-12:],
            'decision': '',
            'feedback': '',
        })

        # ── Evaluator ────────────────────────────────────────────────────
        if _interrupt_event.is_set():
            live.stop()
            _last_session = {"goal": goal, "history": history,
                             "eval_history": eval_history, "workdir": workdir}
            _persist_session(_last_session)
            return _finish('interrupted')

        if iteration % eval_every == 0 or iteration == max_iter:
            refresh("evaluator", iteration)
            eval_prompt = build_evaluator_prompt(goal, last_msg or "", iteration)
            eval_msg, _ = run_evaluator(eval_prompt, workdir, eval_model,
                                        system_prompt=eval_sys)
        else:
            eval_msg = "IMPROVE: (evaluation skipped)"

        decision, feedback = parse_decision(eval_msg)
        history[-1]['decision'] = decision
        history[-1]['feedback'] = feedback
        eval_history.append({
            'iter': iteration,
            'decision': decision,
            'feedback': feedback,
            'full_msg': eval_msg,
        })

        # ── 지식 저장소에 attempt 기록 ───────────────────────────────────
        attempt_record = {
            "timestamp": time.strftime("%Y-%m-%dT%H:%M:%S"),
            "iter": iteration,
            "decision": decision,
            "feedback": feedback,
            "worker_summary": worker_summary,
            "goal": goal,
        }
        _save_attempt(goal, attempt_record)
        past_attempts.append(attempt_record)  # 현재 세션 내 즉시 반영

        # ── 이전 압축 결과 반영 ──────────────────────────────────────────
        if _compress_thread and not _compress_thread.is_alive() and _compress_result:
            history = _compress_result[0]
            _compress_result.clear()
            _compress_thread = None

        # ── 프롬프트 토큰이 100k 초과 시 백그라운드 압축 시작 ────────────
        prompt_tokens = _estimate_tokens(build_worker_prompt(goal, history, past_attempts=past_attempts))
        if (prompt_tokens > TOKEN_COMPRESS_THRESHOLD
                and (_compress_thread is None or not _compress_thread.is_alive())
                and decision != 'DONE'):
            _snap = list(history)  # 스냅샷 캡처
            _res  = _compress_result

            def _do_compress():
                new_h = compress_history(_snap, goal, eval_model)
                _res.clear()
                _res.append(new_h)

            _compress_thread = threading.Thread(target=_do_compress, daemon=True)
            _compress_thread.start()

        if decision == 'DONE':
            done = True
            refresh("done", iteration)
            time.sleep(0.8)
            live.stop()
            _last_session = {
                "goal": goal, "history": history,
                "eval_history": eval_history, "workdir": workdir,
            }
            _persist_session(_last_session)

            # 완료 요약 출력
            console.print()
            console.print(Rule(f"[bold green]✓ 완료 — {iteration}번 반복[/bold green]"))
            console.print()
            for section, color in [('판단 이유', 'white'), ('결과물 위치', 'cyan'), ('결과 요약', 'bright_white')]:
                m = re.search(rf'{section}:\s*(.+?)(?=\n판단|결과물|결과 요약|\Z)', eval_msg, re.S)
                if m:
                    val = m.group(1).strip()
                    console.print(f"[bold]{section}[/bold]")
                    for line in val.splitlines():
                        console.print(f"  [{color}]{line}[/{color}]")
                    console.print()
            return _finish('done')

    live.stop()
    _last_session = {
        "goal": goal, "history": history,
        "eval_history": eval_history, "workdir": workdir,
    }
    _persist_session(_last_session)
    return _finish('max')


# ── Interrupt Handler ─────────────────────────────────────────────────────────

def _handle_interrupt(goal: str, workdir: str, args, max_iter: int) -> str:
    """
    ESC 중단 후 목표 편집 프롬프트 표시.
    새 목표로 루프를 재실행하고, 최종 목표 문자열 반환.
    """
    console.print(
        "\n[yellow]⚠  중단됨.[/yellow] "
        "목표를 수정하거나 Enter로 재실행, Ctrl+C로 REPL 복귀:"
    )
    try:
        new_goal = pt_prompt(
            HTML('<ansiyellow><b>목표 수정</b></ansiyellow> <ansiwhite>></ansiwhite> '),
            default=goal,
            style=PROMPT_STYLE,
        ).strip()
    except (EOFError, KeyboardInterrupt):
        console.print("[dim]취소됨. REPL로 돌아갑니다.[/dim]")
        return goal

    if not new_goal:
        new_goal = goal  # Enter만 누르면 동일 목표 재실행

    layout2 = make_layout()
    layout2["header"].update(render_header(new_goal, 0, max_iter, "idle"))
    layout2["worker"].update(render_worker_panel(deque(), 0, "idle", [], False))
    layout2["evaluator"].update(render_evaluator_panel([], 0, "idle", False))
    live2 = Live(layout2, refresh_per_second=8, screen=False)

    # 목표가 바뀌면 히스토리 없이 fresh 실행
    outcome = run_agent_loop(
        new_goal, workdir, args.worker_model, args.eval_model,
        max_iter, layout2, live2,
    )
    if outcome == 'interrupted':
        return _handle_interrupt(new_goal, workdir, args, max_iter)
    elif outcome == 'max':
        console.print(f"[red]{max_iter}번 반복 후에도 완료되지 않았습니다.[/red]")
    console.print("[dim]다음 명령을 입력하세요. /exit 로 종료.[/dim]")
    return new_goal


# ── Main ──────────────────────────────────────────────────────────────────────

def main():
    # ── tmux 자동 래핑 ─────────────────────────────────────────────────
    # -r / --reconnect: 기존 세션 재접속
    if len(sys.argv) >= 2 and sys.argv[1] in ("-r", "--reconnect"):
        _tmux_reconnect()
        return

    # --new-session: 기존 세션 무시하고 강제로 새 세션
    force_new = len(sys.argv) >= 2 and sys.argv[1] == "--new-session"
    extra_args = [a for a in sys.argv[1:] if a != "--new-session"]

    if not _in_tmux() and _shutil.which("tmux"):
        if force_new and _tmux_session_exists():
            subprocess.run(["tmux", "kill-session", "-t", TMUX_SESSION])
        _tmux_launch(extra_args)
        # execvp 실패 또는 세션 이미 존재 시 여기까지 옴 → 일반 모드로 계속

    parser = argparse.ArgumentParser(
        prog="agentforge",
        description="Worker + Evaluator 인터랙티브 멀티에이전트 CLI",
    )
    sub = parser.add_subparsers(dest="subcommand")

    auth_parser = sub.add_parser("auth", help="인증 관리 (ChatGPT Plus/Pro)")
    auth_sub = auth_parser.add_subparsers(dest="auth_cmd")

    login_parser = auth_sub.add_parser("login", help="로그인")
    login_parser.add_argument("--device", action="store_true",
        help="SSH/헤드리스 환경용 device auth 사용")
    auth_sub.add_parser("logout", help="로그아웃")
    auth_sub.add_parser("status", help="현재 인증 상태 확인")

    parser.add_argument("-d", "--dir", default=".", metavar="DIR",
                        help="작업 디렉토리 (기본: 현재 디렉토리)")
    parser.add_argument("--worker-model", default=None, metavar="MODEL",
                        help="Worker 모델")
    parser.add_argument("--eval-model", default=None, metavar="MODEL",
                        help="Evaluator 모델")
    parser.add_argument("-n", "--max-iterations", type=int, default=DEFAULT_MAX_ITER,
                        metavar="N", help=f"최대 반복 횟수 (기본: {DEFAULT_MAX_ITER})")
    parser.add_argument("--mode", choices=["code", "research"], default="code",
                        help="실행 모드: code(기본) / research(웹 검색·분석)")
    parser.add_argument("--eval-every", type=int, default=1, metavar="N",
                        help="N번 반복마다 Evaluator 실행 (기본: 1, 즉 매번)")
    args = parser.parse_args()

    # ── auth 서브커맨드 ────────────────────────────────────────────────
    if args.subcommand == "auth":
        if not CODEX_BIN.exists():
            console.print(f"[red]Error: codex not found at {CODEX_BIN}[/red]")
            sys.exit(1)
        if args.auth_cmd == "login":
            cmd_auth_login(device=getattr(args, "device", False))
        elif args.auth_cmd == "logout":
            cmd_auth_logout()
        elif args.auth_cmd == "status":
            cmd_auth_status()
        else:
            auth_parser.print_help()
        return

    workdir = str(Path(args.dir).resolve())
    max_iter = args.max_iterations

    # ── 초기 TUI 표시 ─────────────────────────────────────────────────
    layout = make_layout()
    layout["header"].update(render_header("", 0, max_iter, "idle"))
    layout["worker"].update(render_worker_panel(deque(), 0, "idle", [], False))
    layout["evaluator"].update(render_evaluator_panel([], 0, "idle", False))
    with Live(layout, refresh_per_second=8, screen=False) as live:
        time.sleep(0.3)

    # ── REPL 루프 ─────────────────────────────────────────────────────
    status = auth_status()
    if not status or not status["has_token"]:
        console.print(
            "[yellow]⚠  로그인되지 않았습니다.[/yellow] "
            "지금 로그인하시겠습니까? ([bold]y[/bold]/n/device) ",
            end="",
        )
        try:
            ans = input().strip().lower()
        except (EOFError, KeyboardInterrupt):
            ans = "n"
        if ans in ("y", ""):
            cmd_auth_login(device=False)
        elif ans == "device":
            cmd_auth_login(device=True)
        else:
            console.print(
                "[dim]로그인을 건너뜁니다. "
                "agentforge auth login 으로 나중에 로그인할 수 있습니다.[/dim]"
            )

    current_mode = args.mode
    eval_every   = args.eval_every

    # 프로세스 시작 시 디스크에서 마지막 세션 복원
    global _last_session
    if _last_session is None:
        _last_session = _load_persisted_session()
        if _last_session:
            saved_at = _last_session.get('saved_at', '알 수 없음')
            console.print(
                f"[dim]💾 이전 세션 복원됨: [cyan]{_last_session['goal'][:60]}[/cyan] "
                f"({len(_last_session['history'])}회, {saved_at})[/dim]"
            )

    console.print(f"[dim]명령을 입력하세요. /help 로 커맨드 목록 확인. 모드: {current_mode}[/dim]")

    _completer = SlashCompleter()

    while True:
        try:
            raw = pt_prompt(
                HTML('<ansicyan><b>[agentforge]</b></ansicyan> <ansiwhite>></ansiwhite> '),
                completer=_completer,
                complete_while_typing=True,
                style=PROMPT_STYLE,
            ).strip()
        except (EOFError, KeyboardInterrupt):
            console.print("\n[dim]종료합니다.[/dim]")
            break

        if not raw:
            continue

        # 슬래시 커맨드 처리
        if raw.startswith('/'):
            token = raw[1:].split(None, 1)
            cmd_name = token[0].lower() if token else ''
            cmd_arg = token[1] if len(token) > 1 else ''

            if cmd_name == 'exit':
                console.print("[dim]종료합니다.[/dim]")
                break

            elif cmd_name == 'resume':
                if not _last_session:
                    console.print("[yellow]재개할 세션이 없습니다. 먼저 목표를 실행하세요.[/yellow]")
                    continue
                s = _last_session
                prev_iters = len(s["history"])
                saved_at = s.get('saved_at', '알 수 없음')
                console.print(Rule("[cyan]세션 재개[/cyan]"))
                console.print(f"[dim]목표:[/dim]    [white]{s['goal'][:80]}[/white]")
                console.print(f"[dim]반복:[/dim]    {prev_iters}회 완료")
                console.print(f"[dim]저장:[/dim]    {saved_at}")
                last_decision = next(
                    (h['decision'] for h in reversed(s['history'])
                     if h.get('decision') and h.get('type') != 'compressed_summary'),
                    '없음'
                )
                console.print(f"[dim]마지막 판정:[/dim] {last_decision}")
                console.print()
                layout2 = make_layout()
                layout2["header"].update(render_header(s["goal"], prev_iters, max_iter, "idle"))
                layout2["worker"].update(render_worker_panel(deque(), prev_iters, "idle", s["history"], False))
                layout2["evaluator"].update(render_evaluator_panel(s["eval_history"], prev_iters, "idle", False))
                live2 = Live(layout2, refresh_per_second=8, screen=False)
                outcome = run_agent_loop(
                    s["goal"], s["workdir"],
                    args.worker_model, args.eval_model,
                    max_iter, layout2, live2,
                    initial_history=s["history"],
                    initial_eval_history=s["eval_history"],
                    mode=current_mode, eval_every=eval_every,
                )
                if outcome == 'interrupted':
                    console.print("\n[yellow]⚠  중단됨. REPL로 돌아갑니다.[/yellow]")
                elif outcome == 'max':
                    console.print(f"[red]{max_iter}번 반복 후에도 완료되지 않았습니다.[/red]")
                if outcome != 'interrupted':
                    console.print("[dim]다음 명령을 입력하세요. /exit 로 종료.[/dim]")

            elif cmd_name == 'mode':
                if cmd_arg in ('code', 'research'):
                    current_mode = cmd_arg
                    console.print(f"[cyan]모드 변경: {current_mode}[/cyan]")
                else:
                    console.print("[red]사용법: /mode code  또는  /mode research[/red]")

            elif cmd_name == 'eval-every':
                try:
                    eval_every = int(cmd_arg)
                    console.print(f"[cyan]Evaluator: {eval_every}번마다 실행[/cyan]")
                except ValueError:
                    console.print("[red]숫자를 입력하세요. 예: /eval-every 3[/red]")

            elif cmd_name == 'dir':
                if not cmd_arg:
                    console.print(f"현재 작업 디렉토리: [cyan]{workdir}[/cyan]")
                    console.print("[dim]변경: /dir <경로>  예) /dir ~/AgentForge[/dim]")
                else:
                    new_dir = Path(cmd_arg).expanduser().resolve()
                    if not new_dir.exists():
                        console.print(f"[red]존재하지 않는 경로: {new_dir}[/red]")
                    elif not new_dir.is_dir():
                        console.print(f"[red]디렉토리가 아닙니다: {new_dir}[/red]")
                    else:
                        workdir = str(new_dir)
                        console.print(f"[cyan]작업 디렉토리 변경: {workdir}[/cyan]")

            elif cmd_name == 'status':
                console.print(f"모드: [cyan]{current_mode}[/cyan]  |  eval-every: [cyan]{eval_every}[/cyan]  |  dir: [cyan]{workdir}[/cyan]")

            elif cmd_name == 'help':
                for cmd, desc in SLASH_COMMANDS:
                    console.print(f"  [cyan]{cmd:<25}[/cyan] {desc}")

            else:
                console.print(f"[red]알 수 없는 커맨드: /{cmd_name}[/red]")
                console.print("[dim]/help 로 커맨드 목록을 확인하세요.[/dim]")

        else:
            # 일반 텍스트 → 바로 Worker에게 목표로 전달
            goal = raw
            layout2 = make_layout()
            layout2["header"].update(render_header(goal, 0, max_iter, "idle"))
            layout2["worker"].update(render_worker_panel(deque(), 0, "idle", [], False))
            layout2["evaluator"].update(render_evaluator_panel([], 0, "idle", False))
            live2 = Live(layout2, refresh_per_second=8, screen=False)
            outcome = run_agent_loop(
                goal, workdir, args.worker_model, args.eval_model,
                max_iter, layout2, live2,
                mode=current_mode, eval_every=eval_every,
            )
            if outcome == 'interrupted':
                console.print("\n[yellow]⚠  중단됨. REPL로 돌아갑니다.[/yellow]")
            elif outcome == 'max':
                console.print(f"[red]{max_iter}번 반복 후에도 완료되지 않았습니다.[/red]")
            if outcome != 'interrupted':
                console.print("[dim]다음 명령을 입력하세요. /exit 로 종료.[/dim]")


if __name__ == "__main__":
    main()
