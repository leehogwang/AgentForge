def _try_visualize(workdir: str, goal: str) -> list[str]:
    """학습 완료 후 결과 시각화 시도. 생성된 플롯 경로 목록 반환."""
    try:
        import matplotlib
        matplotlib.use('Agg')
        import matplotlib.pyplot as plt
    except ImportError:
        return []

    plots: list[str] = []
    plot_dir = _knowledge_path(goal) / "plots"
    plot_dir.mkdir(exist_ok=True)

    import csv as _csv
    for csv_path in list(Path(workdir).rglob("*.csv"))[:5]:
        try:
            with open(csv_path, newline='', errors='replace') as f:
                rows = list(_csv.DictReader(f))
            if len(rows) < 3:
                continue
            headers = list(rows[0].keys())
            x_col = next((h for h in headers
                          if h.lower() in ('epoch', 'step', 'iteration', 'iter')), None)
            if not x_col:
                continue
            metric_cols = [h for h in headers
                           if any(kw in h.lower() for kw in ('loss', 'acc', 'map', 'f1', 'score', 'auc'))
                           and h != x_col]
            if not metric_cols:
                continue
            n = min(len(metric_cols), 4)
            fig, axes = plt.subplots(1, n, figsize=(5 * n, 4), squeeze=False)
            x = [float(r[x_col]) for r in rows if r.get(x_col, '').strip()]
            for i, col in enumerate(metric_cols[:4]):
                y = []
                for r in rows:
                    try:
                        y.append(float(r[col]))
                    except (ValueError, TypeError):
                        y.append(float('nan'))
                axes[0][i].plot(x[:len(y)], y)
                axes[0][i].set_title(col, fontsize=10)
                axes[0][i].set_xlabel(x_col, fontsize=8)
                axes[0][i].grid(True, alpha=0.3)
            plt.suptitle(csv_path.stem, fontsize=11)
            plt.tight_layout()
            out = plot_dir / f"{csv_path.stem}.png"
            plt.savefig(out, dpi=100, bbox_inches='tight')
            plt.close()
            plots.append(str(out))
        except Exception:
            plt.close('all')

    loss_re = re.compile(r'(?:loss|Loss)[\s:=]+([0-9]+\.?[0-9]*(?:e[-+]?\d+)?)')
    acc_re  = re.compile(r'(?:acc(?:uracy)?|Acc)[\s:=]+([0-9]+\.?[0-9]*)')
    log_files = list(Path(workdir).rglob("*.log")) + list(Path(workdir).rglob("train*.txt"))
    for log_path in log_files[:3]:
        try:
            text = log_path.read_text(errors='replace')
            losses = [float(m) for m in loss_re.findall(text)]
            accs   = [float(m) for m in  acc_re.findall(text)]
            if len(losses) < 3:
                continue
            n = 2 if len(accs) >= 3 else 1
            fig, axes = plt.subplots(1, n, figsize=(6 * n, 4), squeeze=False)
            axes[0][0].plot(losses)
            axes[0][0].set_title('Loss', fontsize=10)
            axes[0][0].set_xlabel('Step', fontsize=8)
            axes[0][0].grid(True, alpha=0.3)
            if n == 2:
                axes[0][1].plot(accs)
                axes[0][1].set_title('Accuracy', fontsize=10)
                axes[0][1].set_xlabel('Step', fontsize=8)
                axes[0][1].grid(True, alpha=0.3)
            plt.suptitle(log_path.stem, fontsize=11)
            plt.tight_layout()
            out = plot_dir / f"{log_path.stem}.png"
            plt.savefig(out, dpi=100, bbox_inches='tight')
            plt.close()
            plots.append(str(out))
        except Exception:
            plt.close('all')

    return plots


