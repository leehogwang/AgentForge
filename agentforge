def render_cmd_bar(buf1, buf2, status1: str, status2: str) -> Panel:
    """하단 상태바: 각 Worker가 현재 실행 중인 마지막 도구 호출 표시."""
    import re as _re
    _markup_re = _re.compile(r'\[/?[a-zA-Z#][^\]]*\]')

    def last_cmd(buf, status: str) -> str:
        # 버퍼에서 마지막 ▶ 도구 호출 라인 추출
        for line in reversed(list(buf)):
            clean = _markup_re.sub('', line).strip()
            if clean.startswith('▶'):
                # 터미널 너비에 맞게 자름
                import shutil as _sh
                w = max(30, _sh.get_terminal_size(fallback=(80, 40)).columns // 2 - 12)
                return clean[:w] + ("…" if len(clean) > w else "")
        if status == "running":
            return "[dim]실행 준비 중...[/dim]"
        if status == "done":
            return "[green dim]완료[/green dim]"
        return "[dim]대기 중[/dim]"

    c1 = "yellow" if status1 == "running" else "dim"
    c2 = "cyan"   if status2 == "running" else "dim"
    line1 = last_cmd(buf1, status1)
    line2 = last_cmd(buf2, status2)
    content = (
        f"[{c1}]W1[/{c1}] [dim]▶[/dim] {line1}\n"
        f"[{c2}]W2[/{c2}] [dim]▶[/dim] {line2}"
    )
    return Panel(content, title="[dim]현재 실행 중[/dim]",
                 border_style="dim", box=box.SIMPLE, padding=(0, 1))


def _fmt_elapsed(start: float) -> str:
    """시작 시각으로부터 경과 시간을 'Xh Ym' 형식으로 반환."""
    secs = int(time.time() - start)
    h, m = divmod(secs // 60, 60)
    if h > 0:
        return f"{h}h {m:02d}m"
    return f"{m}m {secs % 60:02d}s"


