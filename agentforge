# ── Constants ─────────────────────────────────────────────────────────────────

CODEX_BIN = Path.home() / ".npm-global" / "bin" / "codex"
DEFAULT_MAX_ITER = 5000
WORKER_BUF_LINES = 60
ANSI_RE = re.compile(r'\x1b\[[0-9;]*[a-zA-Z]|\x1b\][^\x07]*\x07')
DECISION_RE = re.compile(r'^(DONE|IMPROVE|REDIRECT)(?::\s*(.*))?$', re.I | re.M)
NOISE_RE = re.compile(r'^\s*([\-─═\s]+)?$')

