# ── ESC Listener ──────────────────────────────────────────────────────────────

def _esc_listener(stop: threading.Event):
    """데몬 스레드: ESC 키 감지 시 _interrupt_event 설정."""
    try:
        fd = sys.stdin.fileno()
        old = termios.tcgetattr(fd)
    except Exception:
        return
    try:
        tty.setcbreak(fd)
        while not stop.is_set():
            if select.select([sys.stdin], [], [], 0.1)[0]:
                ch = os.read(fd, 1)
                if ch == b'\x1b':
                    _interrupt_event.set()
                    break
    except Exception:
        pass
    finally:
        try:
            termios.tcsetattr(fd, termios.TCSADRAIN, old)
        except Exception:
            pass


# ── Agent Runners ─────────────────────────────────────────────────────────────

def _run_codex(cmd: list, workdir: str, buf: deque | None,
               status_ref: list | None) -> tuple[str, int]:
    """codex exec 실행. buf가 있으면 stdout 스트리밍. 최종 메시지 반환."""
    with tempfile.NamedTemporaryFile(mode='w', suffix='.txt', delete=False) as f:
        out_file = f.name

    full_cmd = cmd + ["-o", out_file]
    try:
        if buf is not None:
            global _current_proc
            if status_ref:
                status_ref[0] = "running"
            proc = subprocess.Popen(
                full_cmd, stdout=subprocess.PIPE, stderr=subprocess.STDOUT,
                text=True, errors='replace',
            )
            _current_proc = proc
            prev_line = ""
            for raw in proc.stdout:
                clean = strip_ansi(raw).rstrip()
                if clean and not NOISE_RE.match(clean) and clean != prev_line:
                    buf.append(colorize_line(clean))
                    prev_line = clean
            proc.wait()
            _current_proc = None
            rc = proc.returncode
            if status_ref:
                status_ref[0] = "done"
        else:
            proc = subprocess.run(
                full_cmd, capture_output=True, text=True, errors='replace',
            )
            rc = proc.returncode
    except Exception as e:
        if buf is not None:
            buf.append(f"[red][ERROR] {e}[/red]")
        if status_ref:
            status_ref[0] = "error"
        rc = 1

    last_msg = ""
    try:
        last_msg = strip_ansi(Path(out_file).read_text()).strip()
    except Exception:
        if buf:
            last_msg = strip_ansi("\n".join(list(buf)[-10:]))
    finally:
        try:
            Path(out_file).unlink()
        except Exception:
            pass

    return last_msg, rc


def run_worker(prompt: str, workdir: str, model: str | None,
               buf: deque, status_ref: list) -> tuple[str, int]:
    cmd = [
        str(CODEX_BIN), "exec",
        "--full-auto", "--skip-git-repo-check", "--color", "never",
        "-C", workdir,
    ]
    if model:
        cmd += ["-m", model]
    cmd.append(prompt)
    return _run_codex(cmd, workdir, buf, status_ref)


def run_evaluator(prompt: str, workdir: str, model: str | None) -> tuple[str, int]:
    cmd = [
        str(CODEX_BIN), "exec",
        "-s", "read-only", "--skip-git-repo-check", "--color", "never",
        "-C", workdir,
    ]
    if model:
        cmd += ["-m", model]
    cmd.append(prompt)
    return _run_codex(cmd, workdir, None, None)


def run_plan_agent(prompt: str, workdir: str, model: str | None) -> tuple[str, int]:
    cmd = [
        str(CODEX_BIN), "exec",
        "-s", "read-only", "--skip-git-repo-check", "--color", "never",
        "-C", workdir,
    ]
    if model:
        cmd += ["-m", model]
    cmd.append(prompt)
    return _run_codex(cmd, workdir, None, None)


def parse_decision(text: str) -> tuple[str, str]:
    m = DECISION_RE.search(text)
    if m:
        return m.group(1).upper(), (m.group(2) or "").strip()
    lower = text.lower()
    if any(w in lower for w in ['task is complete', 'fully complete', 'goal achieved', 'all done']):
        return 'DONE', ''
    return 'IMPROVE', f"(parse failed) {text[:200]}"


# ── TUI ───────────────────────────────────────────────────────────────────────

def make_layout() -> Layout:
    try:
        term_h = os.get_terminal_size().lines
    except OSError:
        term_h = 40
    body_size = max(10, term_h - 5)  # header(3) + 여백(2)

    layout = Layout()
    layout.split(
        Layout(name="header", size=3),
        Layout(name="body", size=body_size),
    )
    layout["body"].split_row(
        Layout(name="worker"),
        Layout(name="evaluator"),
    )
    return layout


def render_header(goal: str, iteration: int, max_iter: int, phase: str) -> Panel:
    g = goal[:72] + "..." if len(goal) > 72 else goal
    status = {
        "idle":      "[dim]명령 대기 중  /plan <목표>  또는  <목표> 입력[/dim]",
        "worker":    "⚙  [bold yellow on black] WORKER 실행 중 [/bold yellow on black]  [dim]Evaluator 대기[/dim]",
        "evaluator": "[dim]Worker 완료[/dim]  →  ◈  [bold magenta on black] EVALUATOR 평가 중 [/bold magenta on black]",
        "planning":  "◑  [bold cyan on black] PLAN AGENT 실행 중 [/bold cyan on black]",
        "done":      "[bold green]✓  완료[/bold green]",
        "max":       "[bold red]⚠  최대 반복 도달[/bold red]",
    }.get(phase, phase)
    iter_str = f"  Iter [bold]{iteration}[/bold]/{max_iter}" if iteration > 0 else ""
    content = f"[bold cyan]Goal:[/bold cyan] {g}\n{status}{iter_str}"
    return Panel(content, border_style="cyan", box=box.HEAVY_HEAD)


_DECISION_BADGE = {
    "DONE":     "[green]✓[/green]",
    "IMPROVE":  "[yellow]~[/yellow]",
    "REDIRECT": "[red]↩[/red]",
}

def render_worker_panel(buf: deque, iteration: int, status: str,
                        history: list, done: bool) -> Panel:
    lines = []
    # 오래된 기록 (직전 제외): summary 한 줄 + 배지
    for h in history[:-1]:
        badge = _DECISION_BADGE.get(h['decision'], '[dim]?[/dim]')
        summary = (h['worker_summary'] or '')[:70]
        lines.append(f"[dim]Iter {h['iter']}[/dim] {badge} [dim]{summary}[/dim]")
    # 직전 기록: worker_lines 최대 8줄 (밝게)
    if history:
        h = history[-1]
        lines.append(f"[bold]── Iter {h['iter']} ──────────────────────────────[/bold]")
        for l in h.get('worker_lines', [])[-8:]:
            lines.append(f"[white]{l}[/white]")
    # 현재 스트리밍
    if buf or status == "running":
        if history:
            lines.append(f"[yellow bold]── Iter {iteration} (실행 중) ──────────────[/yellow bold]")
        for line in list(buf):
            lines.append(line)
        if status == "running":
            lines.append("[yellow blink]▌[/yellow blink]")
    border = "green" if done else "yellow"
    is_active = (status == "running")
    if done:
        title = "[green bold]✓ WORKER AGENT[/green bold]"
    elif is_active:
        title = "[yellow bold]⚙ WORKER AGENT ◀ 실행 중[/yellow bold]"
    else:
        title = "[dim]⚙ WORKER AGENT[/dim]"
    content = "\n".join(lines) if lines else "[dim]명령을 입력하면 작업을 시작합니다.[/dim]"
    return Panel(
        Text.from_markup(content),
        title=title,
        border_style=border, box=box.ROUNDED, padding=(0, 1),
    )


def render_evaluator_panel(eval_history: list, iteration: int,
                           phase: str, done: bool) -> Panel:
    lines = []
    # 오래된 기록 (최신 제외): 배지 + 요약 한 줄
    for e in eval_history[:-1]:
        d, fb = e['decision'], e['feedback']
        badge = {"DONE": "[green]✓ DONE[/green]",
                 "IMPROVE": "[yellow]IMPROVE[/yellow]",
                 "REDIRECT": "[red]REDIRECT[/red]"}.get(d, d)
        short_fb = fb[:65] + ('…' if len(fb) > 65 else '')
        lines.append(f"[dim]Iter {e['iter']}[/dim] {badge} [dim]{short_fb}[/dim]")
    # 최신 기록: 전체 피드백 표시
    if eval_history:
        e = eval_history[-1]
        d, fb, fm = e['decision'], e['feedback'], e.get('full_msg', '')
        lines.append(f"[bold]── Iter {e['iter']} ──────────────────────────────[/bold]")
        if d == 'DONE':
            lines.append("[bold green]✓ DONE[/bold green]")
            for section in ['판단 이유', '결과물 위치', '결과 요약']:
                m = re.search(rf'{section}:\s*(.+?)(?=\n판단|결과물|결과 요약|$)', fm, re.S)
                if m:
                    val = m.group(1).strip()[:200]
                    lines.append(f"[cyan]{section}:[/cyan] [white]{val}[/white]")
        elif d == 'IMPROVE':
            lines.append("[bold yellow]▲ IMPROVE[/bold yellow]")
            lines.append(f"[yellow]{fb}[/yellow]")
        elif d == 'REDIRECT':
            lines.append("[bold red]↩ REDIRECT[/bold red]")
            lines.append(f"[red]{fb}[/red]")
        lines.append("")
    if phase == "evaluator":
        lines.append(f"[magenta bold]── Iter {iteration} (평가 중) ──────────────[/magenta bold]")
        lines.append("[magenta blink]평가 중...[/magenta blink]")
    elif phase == "planning":
        lines.append("[cyan blink]계획 수립 중...[/cyan blink]")
    border = "green" if done else "magenta"
    is_active = (phase == "evaluator")
    if done:
        title = "[green bold]✓ EVALUATOR AGENT[/green bold]"
    elif is_active:
        title = "[magenta bold]◈ EVALUATOR AGENT ◀ 평가 중[/magenta bold]"
    else:
        title = "[dim]◈ EVALUATOR AGENT[/dim]"
    content = "\n".join(lines) if lines else "[dim]Worker 완료 후 평가를 시작합니다.[/dim]"
    return Panel(
        Text.from_markup(content),
        title=title,
        border_style=border, box=box.ROUNDED, padding=(0, 1),
    )


# ── Plan Mode ─────────────────────────────────────────────────────────────────

def run_plan_mode(raw_goal: str, workdir: str, model: str | None,
                  layout: Layout, live: Live) -> str | None:
    """
    /plan 모드: Plan Agent와 대화 후 최종 계획(목표 문자열)을 반환.
    취소 시 None 반환.
    """
    goal = raw_goal.strip()
    if not goal:
        live.stop()
        try:
            goal = input("계획할 목표를 입력하세요: ").strip()
        except (EOFError, KeyboardInterrupt):
            return None
        if not goal:
            return None

    qa_history = []

    while True:
        # Plan Agent 실행
        layout["header"].update(render_header(goal, 0, 0, "planning"))
        layout["worker"].update(render_worker_panel(deque(), 0, "idle", [], False))
        layout["evaluator"].update(render_evaluator_panel([], 0, "planning", False))
        live.start()
        time.sleep(0.2)

        plan_prompt = build_plan_prompt(goal, qa_history)
        plan_output, _ = run_plan_agent(plan_prompt, workdir, model)

        live.stop()
        console.print()

        # 질문이 있는지 확인
        has_questions = '질문:' in plan_output or re.search(r'^\d+\.\s', plan_output, re.M)
        has_plan = '계획:' in plan_output or re.search(r'^[-•]\s', plan_output, re.M)

        console.print(Rule("[cyan]Plan Agent[/cyan]"))
        console.print(plan_output)
        console.print()

        if has_questions and not has_plan:
            # 질의응답
            console.print("[dim]질문에 답변하세요 (취소: /cancel):[/dim]")
            try:
                answer = input("> ").strip()
            except (EOFError, KeyboardInterrupt):
                return None
            if answer.lower() in ('/cancel', '/exit'):
                return None
            qa_history.append({'q': plan_output, 'a': answer})
            continue  # 다시 Plan Agent 실행

        # 계획 수립 완료 → accept
        console.print("[dim]이 계획으로 진행하시겠습니까? (y: 실행 / n: 다시 작성 / /cancel: 취소)[/dim]")
        try:
            ans = input("accept (y/n) > ").strip().lower()
        except (EOFError, KeyboardInterrupt):
            return None
        if ans == 'y':
            # 계획 내용을 목표로 삼아 반환
            final_goal = f"{goal}\n\n[계획]\n{plan_output}"
            return final_goal
        elif ans in ('/cancel', '/exit'):
            return None
        # n → 다시 처음부터
        qa_history.clear()
        try:
            new_goal = input("새 목표를 입력하거나 Enter로 기존 목표 유지: ").strip()
        except (EOFError, KeyboardInterrupt):
            return None
        if new_goal:
            goal = new_goal


# ── Agent Loop ────────────────────────────────────────────────────────────────

def run_agent_loop(goal: str, workdir: str, worker_model: str | None,
                   eval_model: str | None, max_iter: int,
                   layout: Layout, live: Live,
                   initial_history: list | None = None,
                   initial_eval_history: list | None = None) -> str:
    """
    Worker + Evaluator 반복 루프.
    반환: 'done' | 'max'
    """
    global _last_session
    history = list(initial_history or [])
    eval_history = list(initial_eval_history or [])
    worker_buf = deque(maxlen=WORKER_BUF_LINES)
    worker_status = ["idle"]
    done = False

    # ESC 리스너 시작
    _interrupt_event.clear()
    _esc_stop = threading.Event()
    esc_t = threading.Thread(target=_esc_listener, args=(_esc_stop,), daemon=True)
    esc_t.start()

    def _finish(result: str) -> str:
        _esc_stop.set()
        return result

    def refresh(phase: str, iteration: int):
        layout["header"].update(render_header(goal, iteration, max_iter, phase))
        layout["worker"].update(render_worker_panel(
            worker_buf, iteration, worker_status[0], history, done))
        layout["evaluator"].update(render_evaluator_panel(
            eval_history, iteration, phase, done))

    for iteration in range(1, max_iter + 1):
        # ── Worker ──────────────────────────────────────────────────────
        worker_buf.clear()
        worker_status[0] = "running"
        if not live._started:
            live.start()
        refresh("worker", iteration)

        worker_prompt = build_worker_prompt(goal, history)
        worker_result = [None, None]

        def _worker():
            worker_result[0], worker_result[1] = run_worker(
                worker_prompt, workdir, worker_model, worker_buf, worker_status)

        t = threading.Thread(target=_worker, daemon=True)
        t.start()
        while t.is_alive():
            if _interrupt_event.is_set():
                if _current_proc:
                    _current_proc.kill()
                break
            refresh("worker", iteration)
            time.sleep(0.1)
        t.join()
        refresh("worker", iteration)

        # ESC로 중단된 경우
        if _interrupt_event.is_set():
            live.stop()
            _last_session = {"goal": goal, "history": history,
                             "eval_history": eval_history, "workdir": workdir}
            return _finish('interrupted')

        last_msg, _ = worker_result
        worker_summary = (last_msg or "").replace('\n', ' ')[:300]
        history.append({
            'iter': iteration,
            'worker_summary': worker_summary,
            'worker_lines': list(worker_buf)[-12:],
            'decision': '',
            'feedback': '',
        })

        # ── Evaluator ────────────────────────────────────────────────────
        if _interrupt_event.is_set():
            live.stop()
            _last_session = {"goal": goal, "history": history,
                             "eval_history": eval_history, "workdir": workdir}
            return _finish('interrupted')

        refresh("evaluator", iteration)
        eval_prompt = build_evaluator_prompt(goal, last_msg or "", iteration)
        eval_msg, _ = run_evaluator(eval_prompt, workdir, eval_model)

        decision, feedback = parse_decision(eval_msg)
        history[-1]['decision'] = decision
        history[-1]['feedback'] = feedback
        eval_history.append({
            'iter': iteration,
            'decision': decision,
            'feedback': feedback,
            'full_msg': eval_msg,
        })

        if decision == 'DONE':
            done = True
            refresh("done", iteration)
            time.sleep(0.8)
            live.stop()
            _last_session = {
                "goal": goal, "history": history,
                "eval_history": eval_history, "workdir": workdir,
            }

            # 완료 요약 출력
            console.print()
            console.print(Rule(f"[bold green]✓ 완료 — {iteration}번 반복[/bold green]"))
            console.print()
            for section, color in [('판단 이유', 'white'), ('결과물 위치', 'cyan'), ('결과 요약', 'bright_white')]:
                m = re.search(rf'{section}:\s*(.+?)(?=\n판단|결과물|결과 요약|\Z)', eval_msg, re.S)
                if m:
                    val = m.group(1).strip()
                    console.print(f"[bold]{section}[/bold]")
                    for line in val.splitlines():
                        console.print(f"  [{color}]{line}[/{color}]")
                    console.print()
            return _finish('done')

    live.stop()
    _last_session = {
        "goal": goal, "history": history,
        "eval_history": eval_history, "workdir": workdir,
    }
    return _finish('max')


# ── Interrupt Handler ─────────────────────────────────────────────────────────

def _handle_interrupt(goal: str, workdir: str, args, max_iter: int) -> str:
    """
    ESC 중단 후 목표 편집 프롬프트 표시.
    새 목표로 루프를 재실행하고, 최종 목표 문자열 반환.
    """
    console.print(
        "\n[yellow]⚠  중단됨.[/yellow] "
        "목표를 수정하거나 Enter로 재실행, Ctrl+C로 REPL 복귀:"
    )
    try:
        new_goal = pt_prompt(
            HTML('<ansiyellow><b>목표 수정</b></ansiyellow> <ansiwhite>></ansiwhite> '),
            default=goal,
            style=PROMPT_STYLE,
        ).strip()
    except (EOFError, KeyboardInterrupt):
        console.print("[dim]취소됨. REPL로 돌아갑니다.[/dim]")
        return goal

    if not new_goal:
        new_goal = goal  # Enter만 누르면 동일 목표 재실행

    layout2 = make_layout()
    layout2["header"].update(render_header(new_goal, 0, max_iter, "idle"))
    layout2["worker"].update(render_worker_panel(deque(), 0, "idle", [], False))
    layout2["evaluator"].update(render_evaluator_panel([], 0, "idle", False))
    live2 = Live(layout2, refresh_per_second=8, screen=False)

    # 목표가 바뀌면 히스토리 없이 fresh 실행
    outcome = run_agent_loop(
        new_goal, workdir, args.worker_model, args.eval_model,
        max_iter, layout2, live2,
    )
    if outcome == 'interrupted':
        return _handle_interrupt(new_goal, workdir, args, max_iter)
    elif outcome == 'max':
        console.print(f"[red]{max_iter}번 반복 후에도 완료되지 않았습니다.[/red]")
    console.print("[dim]다음 명령을 입력하세요. /exit 로 종료.[/dim]")
    return new_goal


# ── Main ──────────────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        prog="agentforge",
        description="Worker + Evaluator 인터랙티브 멀티에이전트 CLI",
    )
    sub = parser.add_subparsers(dest="subcommand")

    auth_parser = sub.add_parser("auth", help="인증 관리 (ChatGPT Plus/Pro)")
    auth_sub = auth_parser.add_subparsers(dest="auth_cmd")

    login_parser = auth_sub.add_parser("login", help="로그인")
    login_parser.add_argument("--device", action="store_true",
        help="SSH/헤드리스 환경용 device auth 사용")
    auth_sub.add_parser("logout", help="로그아웃")
    auth_sub.add_parser("status", help="현재 인증 상태 확인")

    parser.add_argument("-d", "--dir", default=".", metavar="DIR",
                        help="작업 디렉토리 (기본: 현재 디렉토리)")
    parser.add_argument("--worker-model", default=None, metavar="MODEL",
                        help="Worker 모델")
    parser.add_argument("--eval-model", default=None, metavar="MODEL",
                        help="Evaluator 모델")
    parser.add_argument("-n", "--max-iterations", type=int, default=DEFAULT_MAX_ITER,
                        metavar="N", help=f"최대 반복 횟수 (기본: {DEFAULT_MAX_ITER})")
    args = parser.parse_args()

    # ── auth 서브커맨드 ────────────────────────────────────────────────
    if args.subcommand == "auth":
        if not CODEX_BIN.exists():
            console.print(f"[red]Error: codex not found at {CODEX_BIN}[/red]")
            sys.exit(1)
        if args.auth_cmd == "login":
            cmd_auth_login(device=getattr(args, "device", False))
        elif args.auth_cmd == "logout":
            cmd_auth_logout()
        elif args.auth_cmd == "status":
            cmd_auth_status()
        else:
            auth_parser.print_help()
        return

    if not CODEX_BIN.exists():
        console.print(f"[bold red]Error:[/bold red] codex not found at {CODEX_BIN}")
        sys.exit(1)

    workdir = str(Path(args.dir).resolve())
    max_iter = args.max_iterations

    # ── 초기 TUI 표시 ─────────────────────────────────────────────────
    layout = make_layout()
    layout["header"].update(render_header("", 0, max_iter, "idle"))
    layout["worker"].update(render_worker_panel(deque(), 0, "idle", [], False))
    layout["evaluator"].update(render_evaluator_panel([], 0, "idle", False))

    live = Live(layout, refresh_per_second=8, screen=False)
    live.start()
    time.sleep(0.3)
    live.stop()

    # ── REPL 루프 ─────────────────────────────────────────────────────
    status = auth_status()
    if not status or not status["has_token"]:
        console.print(
            "[yellow]⚠  로그인되지 않았습니다.[/yellow] "
            "지금 로그인하시겠습니까? ([bold]y[/bold]/n/device) ",
            end="",
        )
        try:
            ans = input().strip().lower()
        except (EOFError, KeyboardInterrupt):
            ans = "n"
        if ans in ("y", ""):
            cmd_auth_login(device=False)
        elif ans == "device":
            cmd_auth_login(device=True)
        else:
            console.print(
                "[dim]로그인을 건너뜁니다. "
                "agentforge auth login 으로 나중에 로그인할 수 있습니다.[/dim]"
            )

    console.print()
    console.print("[dim]명령을 입력하세요. /plan <목표> | /exit[/dim]")

    _completer = SlashCompleter()

    while True:
        try:
            raw = pt_prompt(
                HTML('<ansicyan><b>[agentforge]</b></ansicyan> <ansiwhite>></ansiwhite> '),
                completer=_completer,
                complete_while_typing=True,
                style=PROMPT_STYLE,
            ).strip()
        except (EOFError, KeyboardInterrupt):
            console.print("\n[dim]종료합니다.[/dim]")
            break

        if not raw:
            continue

        # 슬래시 커맨드 처리
        if raw.startswith('/'):
            token = raw[1:].split(None, 1)
            cmd_name = token[0].lower() if token else ''
            cmd_arg = token[1] if len(token) > 1 else ''

            if cmd_name == 'exit':
                console.print("[dim]종료합니다.[/dim]")
                break

            elif cmd_name == 'plan':
                # Plan 모드
                layout["header"].update(render_header(cmd_arg or "", 0, max_iter, "idle"))
                layout["worker"].update(render_worker_panel(deque(), 0, "idle", [], False))
                layout["evaluator"].update(render_evaluator_panel([], 0, "idle", False))

                final_goal = run_plan_mode(cmd_arg, workdir, args.worker_model, layout, live)
                if final_goal is None:
                    console.print("[dim]계획 취소됨.[/dim]")
                    continue
                console.print()
                console.print("[cyan]계획 확정. Worker + Evaluator 루프를 시작합니다...[/cyan]")
                time.sleep(0.5)
                # 새 layout/live 인스턴스로 루프 실행
                layout2 = make_layout()
                layout2["header"].update(render_header(final_goal, 0, max_iter, "idle"))
                layout2["worker"].update(render_worker_panel(deque(), 0, "idle", [], False))
                layout2["evaluator"].update(render_evaluator_panel([], 0, "idle", False))
                live2 = Live(layout2, refresh_per_second=8, screen=False)
                outcome = run_agent_loop(
                    final_goal, workdir, args.worker_model, args.eval_model,
                    max_iter, layout2, live2,
                )
                goal = final_goal
                if outcome == 'interrupted':
                    goal = _handle_interrupt(goal, workdir, args, max_iter)
                elif outcome == 'max':
                    console.print(f"[red]{max_iter}번 반복 후에도 완료되지 않았습니다.[/red]")
                if outcome != 'interrupted':
                    console.print("[dim]다음 명령을 입력하세요. /exit 로 종료.[/dim]")

            elif cmd_name == 'resume':
                if not _last_session:
                    console.print("[yellow]재개할 세션이 없습니다. 먼저 목표를 실행하세요.[/yellow]")
                    continue
                s = _last_session
                prev_iters = len(s["history"])
                console.print(Rule("[cyan]세션 재개[/cyan]"))
                console.print(f"[dim]목표:[/dim] {s['goal'][:80]}")
                console.print(f"[dim]이전 반복:[/dim] {prev_iters}회  →  이어서 실행")
                console.print()
                layout2 = make_layout()
                layout2["header"].update(render_header(s["goal"], prev_iters, max_iter, "idle"))
                layout2["worker"].update(render_worker_panel(deque(), prev_iters, "idle", s["history"], False))
                layout2["evaluator"].update(render_evaluator_panel(s["eval_history"], prev_iters, "idle", False))
                live2 = Live(layout2, refresh_per_second=8, screen=False)
                outcome = run_agent_loop(
                    s["goal"], s["workdir"],
                    args.worker_model, args.eval_model,
                    max_iter, layout2, live2,
                    initial_history=s["history"],
                    initial_eval_history=s["eval_history"],
                )
                goal = s["goal"]
                if outcome == 'interrupted':
                    goal = _handle_interrupt(goal, workdir, args, max_iter)
                elif outcome == 'max':
                    console.print(f"[red]{max_iter}번 반복 후에도 완료되지 않았습니다.[/red]")
                if outcome != 'interrupted':
                    console.print("[dim]다음 명령을 입력하세요. /exit 로 종료.[/dim]")

            else:
                console.print(f"[red]알 수 없는 커맨드: /{cmd_name}[/red]")
                console.print("[dim]사용 가능: /plan <목표>  /resume  /exit[/dim]")

        else:
            # 일반 텍스트 → 바로 Worker에게 목표로 전달
            goal = raw
            layout2 = make_layout()
            layout2["header"].update(render_header(goal, 0, max_iter, "idle"))
            layout2["worker"].update(render_worker_panel(deque(), 0, "idle", [], False))
            layout2["evaluator"].update(render_evaluator_panel([], 0, "idle", False))
            live2 = Live(layout2, refresh_per_second=8, screen=False)
            outcome = run_agent_loop(
                goal, workdir, args.worker_model, args.eval_model,
                max_iter, layout2, live2,
            )
            if outcome == 'interrupted':
                goal = _handle_interrupt(goal, workdir, args, max_iter)
            elif outcome == 'max':
                console.print(f"[red]{max_iter}번 반복 후에도 완료되지 않았습니다.[/red]")
            if outcome != 'interrupted':
                console.print("[dim]다음 명령을 입력하세요. /exit 로 종료.[/dim]")


if __name__ == "__main__":
    main()
