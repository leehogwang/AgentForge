def _estimate_tokens(text: str) -> int:
    """토큰 수 추정. tiktoken 있으면 정확하게, 없으면 글자 수 기반 근사."""
    try:
        import tiktoken
        enc = tiktoken.get_encoding("cl100k_base")
        return len(enc.encode(text))
    except Exception:
        # 영문 ~4자/토큰, 한글 ~1.5자/토큰 혼합 근사 → 3자/토큰
        return len(text) // 3

