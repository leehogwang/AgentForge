    }.get(phase, phase)
    iter_str = f"  Iter [bold]{iteration}[/bold]/{max_iter}" if iteration > 0 else ""
    elapsed_str = f"  [dim]⏱ {_fmt_elapsed(session_start)}[/dim]" if session_start else ""
    content = f"[bold cyan]Goal:[/bold cyan] {g}\n{status}{iter_str}{elapsed_str}"
    if rag_note:
        content += f"\n{rag_note}"
    return Panel(content, border_style="cyan", box=box.HEAVY_HEAD)


_DECISION_BADGE = {
    "DONE":     "[green]✓[/green]",
    "IMPROVE":  "[yellow]~[/yellow]",
    "REDIRECT": "[red]↩[/red]",
}

# 파일 경로 패턴 (절대경로 or ./상대경로)
_PATH_RE = re.compile(r'(/[\w./\-_@:~가-힣]+(?:\.\w+)?|\.{1,2}/[\w./\-_@:~가-힣]+(?:\.\w+)?)')

def _osc8_linkify(text: str) -> str:
    """
    텍스트 내 파일 경로를 OSC 8 하이퍼링크로 변환.
    터미널에서 Ctrl+클릭 시 파일/폴더 열림 (VSCode, iTerm2 등 지원).
    """
    def replace(m: re.Match) -> str:
        path = m.group(0)
        p = Path(path).expanduser()
        if p.exists():
            uri = f"file://{p.resolve()}"
            # OSC 8 이스케이프: \x1b]8;;URI\x1b\\TEXT\x1b]8;;\x1b\\
            return f"\x1b]8;;{uri}\x1b\\{path}\x1b]8;;\x1b\\"
        return path
    return _PATH_RE.sub(replace, text)

def render_worker_panel(buf: deque, iteration: int, status: str,
                        history: list, done: bool, label: str = "WORKER") -> Panel:
    lines = []
    # 오래된 기록 (직전 제외): summary 한 줄 + 배지
    for h in history[:-1]:
        badge = _DECISION_BADGE.get(h['decision'], '[dim]?[/dim]')
        summary = (h['worker_summary'] or '')[:70]
        lines.append(f"[dim]Iter {h['iter']}[/dim] {badge} [dim]{summary}[/dim]")
    # 직전 기록: worker_lines 최대 8줄 (밝게)
    if history:
        h = history[-1]
        lines.append(f"[bold]── Iter {h['iter']} ──────────────────────────────[/bold]")
        for l in h.get('worker_lines', [])[-8:]:
            lines.append(f"[white]{l}[/white]")
    # 현재 스트리밍
    if buf or status == "running":
        if history:
            lines.append(f"[yellow bold]── Iter {iteration} (실행 중) ──────────────[/yellow bold]")
        for line in list(buf):
            lines.append(line)
        if status == "running":
            lines.append("[yellow blink]▌[/yellow blink]")
    border = "green" if done else "yellow"
    is_active = (status == "running")
    if done:
        title = f"[green bold]✓ {label}[/green bold]"
    elif is_active:
        title = f"[yellow bold]⚙ {label} ◀ 실행 중[/yellow bold]"
    else:
        title = f"[dim]⚙ {label}[/dim]"
    content = "\n".join(lines) if lines else "[dim]명령을 입력하면 작업을 시작합니다.[/dim]"
    return Panel(
        Text.from_markup(content),
        title=title,
        border_style=border, box=box.ROUNDED, padding=(0, 1),
    )


def render_evaluator_panel(eval_history: list, iteration: int,
                           phase: str, done: bool) -> Panel:
    lines = []
    # 오래된 기록 (최신 제외): 배지 + 요약 한 줄
    for e in eval_history[:-1]:
        d, fb = e['decision'], e['feedback']
        short_fb = fb[:65] + ('…' if len(fb) > 65 else '')
        if e.get('type') == 'monitor':
            badge = {"DONE": "[green]✓[/green]",
                     "CONTINUE": "[blue]→[/blue]",
                     "KILL": "[red]✗[/red]"}.get(d, '[dim]?[/dim]')
            lines.append(f"[dim]Poll {e['iter']}[/dim] {badge} [dim]{short_fb}[/dim]")
        else:
            badge = {"DONE": "[green]✓ DONE[/green]",
                     "IMPROVE": "[yellow]IMPROVE[/yellow]",
                     "REDIRECT": "[red]REDIRECT[/red]"}.get(d, d)
            lines.append(f"[dim]Iter {e['iter']}[/dim] {badge} [dim]{short_fb}[/dim]")
    # 최신 기록: 전체 피드백 표시
    if eval_history:
        e = eval_history[-1]
        d, fb, fm = e['decision'], e['feedback'], e.get('full_msg', '')
        lines.append(f"[bold]── Iter {e['iter']} ──────────────────────────────[/bold]")
        if d == 'DONE':
            lines.append("[bold green]✓ DONE[/bold green]")
            for section in ['판단 이유', '결과물 위치', '결과 요약']:
                m = re.search(rf'{section}:\s*(.+?)(?=\n판단|결과물|결과 요약|$)', fm, re.S)
                if m:
                    val = m.group(1).strip()[:200]
                    lines.append(f"[cyan]{section}:[/cyan] [white]{val}[/white]")
        elif d == 'IMPROVE':
            lines.append("[bold yellow]▲ IMPROVE[/bold yellow]")
            lines.append(f"[yellow]{fb}[/yellow]")
        elif d == 'REDIRECT':
            lines.append("[bold red]↩ REDIRECT[/bold red]")
            lines.append(f"[red]{fb}[/red]")
        lines.append("")
    if phase == "evaluator":
        lines.append(f"[magenta bold]── Iter {iteration} (평가 중) ──────────────[/magenta bold]")
        lines.append("[magenta blink]평가 중...[/magenta blink]")
    border = "green" if done else "magenta"
    is_active = (phase == "evaluator")
    if done:
        title = "[green bold]✓ EVALUATOR AGENT[/green bold]"
    elif is_active:
        title = "[magenta bold]◈ EVALUATOR AGENT ◀ 평가 중[/magenta bold]"
    else:
        title = "[dim]◈ EVALUATOR AGENT[/dim]"
    content = "\n".join(lines) if lines else "[dim]Worker 완료 후 평가를 시작합니다.[/dim]"
    return Panel(
        Text.from_markup(content),
        title=title,
        border_style=border, box=box.ROUNDED, padding=(0, 1),
    )


def render_dual_evaluator_panel(eval_history1: list, eval_history2: list,
                                 iteration: int, phase: str, done1: bool, done2: bool) -> Panel:
    def _block(hist, label, done, active):
        if not hist:
            return f"[dim]{label}: 대기 중[/dim]"
        e = hist[-1]
        badge = {"DONE": "[green]✓[/green]", "IMPROVE": "[yellow]▲[/yellow]",
                 "REDIRECT": "[red]↩[/red]", "GPU_PICK": "[red bold]![/red bold]"
                }.get(e['decision'], "?")
        fb = e['feedback'][:45] + ("…" if len(e['feedback']) > 45 else "")
        blink = " [blink]평가 중[/blink]" if active else ""
        return f"[bold]{label}[/bold] {badge} Iter {e['iter']}: [dim]{fb}[/dim]{blink}"

    e1_active = phase in ("dual_evaluator",)
    e2_active = phase in ("dual_evaluator",)
    lines = [
        _block(eval_history1, "E1 (W1)", done1, e1_active),
        "[dim]" + "─" * 22 + "[/dim]",
        _block(eval_history2, "E2 (W2)", done2, e2_active),
    ]
    border = "green" if (done1 and done2) else "magenta"
    is_active = phase == "dual_evaluator"
    title = ("[green bold]✓ EVALUATORS[/green bold]" if done1 and done2 else
             "[magenta bold]◈ EVALUATORS ◀ 평가 중[/magenta bold]" if is_active else
             "[dim]◈ EVALUATORS[/dim]")
    return Panel(Text.from_markup("\n".join(lines)),
                 title=title, border_style=border, box=box.ROUNDED, padding=(0, 1))


# ── tmux 자동 래핑 ────────────────────────────────────────────────────────────

import shlex as _shlex
import shutil as _shutil

TMUX_SESSION = "agentforge"


def _in_tmux() -> bool:
    return bool(os.environ.get("TMUX"))


def _tmux_session_exists() -> bool:
    r = subprocess.run(["tmux", "has-session", "-t", TMUX_SESSION],
                       capture_output=True)
    return r.returncode == 0


def _tmux_launch(extra_args: list):
    """현재 프로세스를 tmux 세션 안의 agentforge로 교체."""
    if _tmux_session_exists():
        console.print(
            f"[yellow]이미 실행 중인 agentforge 세션이 있습니다.[/yellow]\n"
            f"  재접속:  [cyan]agentforge -r[/cyan]\n"
            f"  새 세션: [cyan]agentforge --new-session[/cyan]"
        )
        sys.exit(0)

    exe = _shutil.which("agentforge") or os.path.abspath(sys.argv[0])
    cmd_str = " ".join(_shlex.quote(p) for p in [exe] + extra_args)
    try:
        os.execvp("tmux", ["tmux", "new-session", "-s", TMUX_SESSION, cmd_str])
    except OSError:
        pass  # tmux 실행 실패 → 그냥 일반 모드로 계속


def _tmux_reconnect():
    """기존 agentforge tmux 세션에 재접속."""
    if not _shutil.which("tmux"):
        console.print("[red]tmux가 설치되지 않았습니다.[/red]")
        sys.exit(1)
    if not _tmux_session_exists():
        console.print(
            "[yellow]실행 중인 agentforge 세션이 없습니다.[/yellow]\n"
            "새 세션 시작: [cyan]agentforge[/cyan]"
        )
        sys.exit(1)
    os.execvp("tmux", ["tmux", "attach-session", "-t", TMUX_SESSION])


# ── Checkpoint / Rollback ────────────────────────────────────────────────────

def _cp_save(workdir: str) -> str | None:
    """현재 uncommitted 변경사항을 patch 파일로 저장.
    반환: 파일경로 | 'empty'(변경없음) | None(git없음/실패)"""
    if not (Path(workdir) / ".git").exists():
        return None
    try:
        r = subprocess.run(
            ["git", "diff", "HEAD", "--binary"],
            capture_output=True, text=True, cwd=workdir, timeout=10,
        )
        if not r.stdout.strip():
            return "empty"
        p = Path(workdir) / f".agentforge_cp_{int(time.time()*1000)}.patch"
        p.write_text(r.stdout)
        return str(p)
    except Exception:
        return None


def _cp_restore(workdir: str, patch_path: str | None) -> bool:
    """patch 파일로 workdir 복원 (현재 변경 전부 취소 후 적용). True=성공."""
    if patch_path is None:
        return False
    try:
        subprocess.run(["git", "checkout", "."], capture_output=True, cwd=workdir, timeout=10)
        subprocess.run(["git", "clean", "-fd"], capture_output=True, cwd=workdir, timeout=10)
        if patch_path == "empty":
            return True
        r = subprocess.run(
            ["git", "apply", "--whitespace=fix", patch_path],
            capture_output=True, cwd=workdir, timeout=10,
        )
        return r.returncode == 0
    except Exception:
        return False


def _cp_delete(patch_path: str | None) -> None:
    if patch_path and patch_path != "empty":
        try:
            Path(patch_path).unlink(missing_ok=True)
        except Exception:
            pass


def _detect_gpu_in_command(cmd: str) -> int | None:
    m = _GPU_RE.search(cmd)
    if not m: return None
    for g in m.groups():
        if g is not None:
            try: return int(g)
            except ValueError: return None
    return None

def _list_all_gpus() -> list[dict]:
    """전체 GPU 목록 반환: [{id, name, used_mb, total_mb, util}]"""
    try:
        r = subprocess.run(
            ["nvidia-smi",
             "--query-gpu=index,name,memory.used,memory.total",
             "--format=csv,noheader,nounits"],
            capture_output=True, text=True, timeout=5)
        if r.returncode != 0: return []
        gpus = []
        for line in r.stdout.strip().splitlines():
            parts = [p.strip() for p in line.split(',')]
            if len(parts) == 4:
                used, total = float(parts[2]), float(parts[3])
                gpus.append({
                    "id": int(parts[0]), "name": parts[1],
                    "used_mb": used, "total_mb": total,
                    "util": used / total if total > 0 else 0.0,
                })
        return gpus
    except Exception:
        return []

def _check_gpu_capacity(gpu_id: int) -> float | None:
    """Used/total ratio (0.0~1.0). None if unavailable."""
    try:
        r = subprocess.run(
            ["nvidia-smi", "--query-gpu=index,memory.used,memory.total",
             "--format=csv,noheader,nounits"],
            capture_output=True, text=True, timeout=5)
        if r.returncode != 0: return None
        for line in r.stdout.splitlines():
            parts = [p.strip() for p in line.split(',')]
            if len(parts) == 3 and parts[0] == str(gpu_id):
                used, total = float(parts[1]), float(parts[2])
                return used / total if total > 0 else 0.0
    except Exception:
        return None
    return None


def _git_diff_stat(workdir: str) -> str:
    try:
        r = subprocess.run(
            ["git", "diff", "HEAD", "--stat"],
            capture_output=True, text=True, cwd=workdir, timeout=10,
        )
        return r.stdout.strip()[:600] or "(변경 없음)"
    except Exception:
        return "(diff 수집 실패)"


# ── Stagnation Detection ──────────────────────────────────────────────────────

def _detect_stagnation(history: list, threshold: int = STAGNATION_THRESHOLD) -> bool:
    """CONTINUE를 건너뛰고 IMPROVE/REDIRECT만 추출해 N회 유사 피드백이면 정체."""
    real = [h for h in history if h.get('type') != 'compressed_summary']
    # CONTINUE는 무시하고 IMPROVE/REDIRECT만 추출
    improve_only = [h for h in real if h.get('decision') in ('IMPROVE', 'REDIRECT')]
    if len(improve_only) < threshold:
        return False
    recent = improve_only[-threshold:]
    feedbacks = [h.get('feedback', '')[:80] for h in recent]
    summaries = [h.get('worker_summary', '')[:80] for h in recent]
    # 완전 동일
    if len(set(feedbacks)) == 1 or len(set(summaries)) == 1:
        return True
    # 단어 겹침으로 유사도 판단 (Jaccard ≥ 0.3 → 유사)
    def _jaccard(a: str, b: str) -> float:
        sa, sb = set(a.lower().split()), set(b.lower().split())
        if not sa or not sb:
            return 0.0
        return len(sa & sb) / len(sa | sb)
    for i in range(len(feedbacks) - 1):
        if _jaccard(feedbacks[i], feedbacks[i + 1]) < 0.3:
            return False
    return True


# ── A/B Strategy Fork ────────────────────────────────────────────────────────

def _run_ab_strategy(
    goal: str, history: list, workdir: str,
    worker_model: str | None, worker_sys: str, active_tools: list,
    eval_model: str | None, past_attempts: list,
    worker_buf: deque, iteration: int, refresh,
) -> tuple[str | None, str]:
    """
    2개의 Worker를 서로 다른 전략으로 순차 실행하고 Evaluator가 더 나은 쪽 채택.
    반환: (selected_output, "A" | "B" | "interrupted")
    """
    base_patch = _cp_save(workdir)
    if base_patch is None:
        worker_buf.append("[yellow]⚠ git 없음 — A/B 분기는 git 저장소에서만 동작합니다. 단일 Worker로 계속합니다.[/yellow]")
        return None, "no_git"

    HINTS = [
        "\n\n[STRATEGY A] 이전에 시도한 방법과 완전히 다른 접근법을 사용하라. 기존 시도와 겹치는 방법은 금지.",
        "\n\n[STRATEGY B] 문제를 가장 작은 단위로 분해하여 핵심 원인부터 해결하라. 가장 기본적이고 단순한 것부터 시작.",
    ]

    outputs: list[str] = []
    patches: list[str | None] = []   # base + 각 전략 적용 후 전체 patch

    for i, (label, hint) in enumerate([("A", HINTS[0]), ("B", HINTS[1])]):
        if _interrupt_event.is_set():
            _cp_delete(base_patch)
            return None, "interrupted"

        if i == 1:
            # A 실행 후 base 상태로 복원
            _cp_restore(workdir, base_patch)

        worker_buf.append(f"[cyan bold]── 전략 {label} ─────────────────────────────[/cyan bold]")
        refresh("worker", iteration)

        prompt = build_worker_prompt(goal, history, past_attempts=past_attempts) + hint
        buf_tmp: deque = deque(maxlen=WORKER_BUF_LINES)
        status_tmp = ["idle"]
        res: list = [None]

        def _w(p=prompt, b=buf_tmp, s=status_tmp):
            out, _ = run_worker(p, workdir, worker_model, b, s,
                                system_prompt=worker_sys, tools=active_tools)
            res[0] = out

        t = threading.Thread(target=_w, daemon=True)
        t.start()
        while t.is_alive():
            if _interrupt_event.is_set():
                break
            for line in list(buf_tmp):
                worker_buf.append(f"[dim][{label}][/dim] {line}")
            buf_tmp.clear()
            refresh("worker", iteration)
            time.sleep(0.1)
        t.join(timeout=10)

        if _interrupt_event.is_set():
            _cp_delete(base_patch)
            return None, "interrupted"

        outputs.append(res[0] or "")
        # 이 전략의 전체 상태를 patch로 저장 (base + 이 전략의 변경)
        patches.append(_cp_save(workdir))

    # ── Evaluator: A vs B 비교 ───────────────────────────────────────────────
    worker_buf.append("[magenta bold]── Evaluator: 전략 A vs B 비교 중 ──────────[/magenta bold]")
    refresh("evaluator", iteration)

    compare_prompt = "\n".join([
        f"GOAL: {goal}",
        "",
        "=== 전략 A 실행 결과 ===",
        outputs[0][-2000:],
        "",
        "=== 전략 B 실행 결과 ===",
        outputs[1][-2000:],
        "",
        "어느 전략이 목표에 더 가까운가?",
    ])
    eval_msg, _ = run_evaluator(compare_prompt, workdir, eval_model,
                                system_prompt=AB_COMPARE_SYSTEM)

    m = _AB_PICK_RE.search(eval_msg)
    chosen = m.group(1).upper() if m else "B"
    worker_buf.append(f"[green bold]✓ 전략 {chosen} 채택됨[/green bold]")
    refresh("worker", iteration)

    chosen_idx = 0 if chosen == "A" else 1
    other_idx  = 1 - chosen_idx

    # 선택된 전략의 상태를 workdir에 적용
    # 현재 상태 = B's patch → chosen이 A면 restore A's patch
    if chosen == "A":
        _cp_restore(workdir, patches[0])   # A 상태 복원
    # chosen == "B": 현재 상태가 이미 B이므로 그대로

    # 패치 파일 정리
    _cp_delete(base_patch)
    _cp_delete(patches[other_idx])
    # 선택된 전략의 patch는 이미 적용됐으므로 삭제
    _cp_delete(patches[chosen_idx])

    return outputs[chosen_idx], chosen


# ── Training Monitor ──────────────────────────────────────────────────────────

def _read_log_tail(log_path: str, lines: int = 200) -> str:
    """파일 끝에서 N줄 효율적으로 읽기 (최대 32KB seek)."""
    try:
        p = Path(log_path)
        if not p.exists():
            return "(log file not found)"
        size = p.stat().st_size
        with open(log_path, 'rb') as f:
            if size > 32768:
                f.seek(-32768, 2)
                raw = f.read()[1:]
            else:
                raw = f.read()
        text = raw.decode('utf-8', errors='replace')
        return "\n".join(text.splitlines()[-lines:])
    except Exception as e:
        return f"(error reading log: {e})"


def _is_proc_alive(pid: int, proc) -> bool:
    if proc is not None:
        return proc.poll() is None
    try:
        os.kill(pid, 0)
        return True
    except (ProcessLookupError, PermissionError):
        return False


def _build_monitor_prompt(goal: str, log_tail: str, pid: int,
                           elapsed: float, poll_count: int) -> str:
    return "\n".join([
        f"TRAINING GOAL: {goal}",
        f"PID: {pid}  |  Elapsed: {int(elapsed // 60)}m {int(elapsed % 60)}s  |  Poll #{poll_count}",
        "",
        "TRAINING LOG (last 200 lines):",
        "─" * 60,
        log_tail.strip(),
        "─" * 60,
        "",
        "First line: CONTINUE, DONE, or KILL: <reason>",
    ])


def _cleanup_bg(bg: dict) -> None:
    """백그라운드 job proc + log FD 정리."""
    proc = bg.get("proc")
    with _active_procs_lock:
        if proc:
            _active_procs.discard(proc)
    log_fd = getattr(proc, "_agentforge_log_fd", None) if proc else None
    if log_fd:
        try:
            log_fd.close()
        except Exception:
            pass


def _run_monitor_loop(bg: dict, goal: str, workdir: str, eval_model: str | None,
                      poll_sec: int, layout, live, worker_buf: deque,
                      eval_history: list, iteration: int, refresh) -> str:
    """
    poll_sec 마다 로그 확인 → 모니터 Evaluator 실행.
    반환: "DONE" | "KILL:<reason>" | "natural_exit" | "interrupted"
    """
    pid = bg["pid"]
    log_path = bg["log_path"]
    proc = bg.get("proc")

    while True:
        # poll_sec 대기 (100ms 단위로 인터럽트/자연종료 체크)
        deadline = time.time() + poll_sec
        proc_exited = False
        while time.time() < deadline:
            if _interrupt_event.is_set():
                _cleanup_bg(bg)
                return "interrupted"
            if not _is_proc_alive(pid, proc):
                worker_buf.append(f"[green]PID {pid} 자연 종료됨[/green]")
                proc_exited = True
                break
            refresh("worker", iteration)
            time.sleep(0.1)

        if _interrupt_event.is_set():
            _cleanup_bg(bg)
            return "interrupted"

        bg["poll_count"] += 1
        bg["last_poll_at"] = time.time()
        elapsed = time.time() - bg["started_at"]

        log_tail = _read_log_tail(log_path)
        monitor_prompt = _build_monitor_prompt(goal, log_tail, pid, elapsed, bg["poll_count"])

        refresh("evaluator", iteration)
        eval_msg, _ = run_evaluator(monitor_prompt, workdir, eval_model,
                                    system_prompt=MONITOR_EVALUATOR_SYSTEM)
        decision, feedback = parse_decision(eval_msg)
        decision = decision.upper()

        eval_history.append({
            "iter": f"{iteration}.{bg['poll_count']}",
            "decision": decision,
            "feedback": feedback,
            "full_msg": eval_msg,
            "type": "monitor",
        })
        worker_buf.append(
            f"[cyan]Monitor #{bg['poll_count']}: {decision}"
            + (f" — {feedback[:80]}" if feedback else "")
            + "[/cyan]"
        )
        refresh("worker", iteration)

        if decision == "DONE":
            _cleanup_bg(bg)
            return "DONE"
        elif decision == "KILL":
            try:
                os.killpg(os.getpgid(pid), _signal.SIGKILL)
                if proc:
                    proc.wait()
            except (ProcessLookupError, OSError):
                pass
            _cleanup_bg(bg)
            return f"KILL:{feedback}"
        else:  # CONTINUE or anything else
            if proc_exited or not _is_proc_alive(pid, proc):
                _cleanup_bg(bg)
                return "natural_exit"
            # 다음 poll 사이클로


# ── Agent Loop ────────────────────────────────────────────────────────────────

def run_agent_loop(goal: str, workdir: str, worker_model: str | None,
                   eval_model: str | None, max_iter: int,
                   layout: Layout, live: Live,
                   initial_history: list | None = None,
                   initial_eval_history: list | None = None,
                   mode: str = "code",
                   eval_every: int = 1,
                   train_poll_seconds: int = 300,
                   session_context: list | None = None) -> str:
    """
    Worker + Evaluator 반복 루프.
    반환: 'done' | 'max' | 'interrupted'
    """
    global _last_session
    history = list(initial_history or [])
    eval_history = list(initial_eval_history or [])
    worker_buf = deque(maxlen=WORKER_BUF_LINES)
    worker_status = ["idle"]
    done = False
    bg_train: dict | None = None   # 백그라운드 학습 job 추적
    ab_cooldown = 0                # A/B 직후 N회는 정체 감지 억제
    _session_start = time.time()   # 세션 시작 시각

    # 모드별 시스템 프롬프트 및 도구 선택
    worker_sys   = RESEARCH_WORKER_SYSTEM if mode == "research" else WORKER_SYSTEM
    eval_sys     = RESEARCH_EVALUATOR_SYSTEM if mode == "research" else EVALUATOR_SYSTEM
    base_tools   = RESEARCH_TOOLS if mode == "research" else WORKER_TOOLS
    active_tools = base_tools + _mcp_all_tools()

    # 압축 상태 — 백그라운드 압축 스레드 결과 수신용
    _compress_result: list[list] = []   # [new_history] 채워지면 완료
    _compress_thread: threading.Thread | None = None

    # ── 지식 저장소 로드 ─────────────────────────────────────────────────
    past_attempts = _load_past_attempts(goal)
    knowledge_dir = _knowledge_path(goal)
    similar_dirs = _find_similar_goals(goal, threshold=0.6)
    if past_attempts:
        if similar_dirs:
            _rag_note = (
                f"[dim]📚 RAG: {len(past_attempts)}개 시도 로드"
                f" ([cyan]+{len(similar_dirs)}개 유사 목표 병합[/cyan]:"
                + ", ".join(d.name[:30] for d in similar_dirs[:3]) + ")[/dim]"
            )
        else:
            _rag_note = f"[dim]📚 RAG: {len(past_attempts)}개 과거 시도 로드 (exact match)[/dim]"
    else:
        _rag_note = "[dim]📚 RAG: 매칭 없음 — 새 목표로 시작[/dim]"

    def _finish(result: str) -> str:
        return result

    # ── DEBUG: 로그 파일 경로 설정 (agentforge 실행 위치에 생성) ───────────────
    global _DEBUG_LOG_PATH
    _DEBUG_LOG_PATH = str(Path(workdir) / f"agentforge_debug_{_dt.datetime.now().strftime('%Y%m%d_%H%M%S')}.log")
    _dbg("LOOP", f"SESSION_START  mode={mode}  workdir={workdir}  goal={goal[:80]}")
    # ── END DEBUG ────────────────────────────────────────────────────────────

    def refresh(phase: str, iteration: int):
        layout["header"].update(render_header(goal, iteration, max_iter, phase, _rag_note, _session_start))
        layout["worker"].update(render_worker_panel(
            worker_buf, iteration, worker_status[0], history, done))
        layout["evaluator"].update(render_evaluator_panel(
            eval_history, iteration, phase, done))
        layout["cmd_bar"].update(
            render_cmd_bar(worker_buf, deque(), worker_status[0], "idle")
        )

    for iteration in range(1, max_iter + 1):
        # ── DEBUG: 이터레이션 시작 ────────────────────────────────────────
        _dbg("LOOP", f"ITER_START  iteration={iteration}")
        _iter_t0 = time.time()
        # ── END DEBUG ────────────────────────────────────────────────────
        # ── Worker ──────────────────────────────────────────────────────
        worker_buf.clear()
        worker_status[0] = "running"
        if not live._started:
            live.start()
        refresh("worker", iteration)

        # 체크포인트 저장 (REDIRECT 시 롤백용)
        cp_before = _cp_save(workdir)

        # ── 정체 감지 → A/B 전략 분기 ───────────────────────────────────
        if ab_cooldown > 0:
            ab_cooldown -= 1
        stagnated = ab_cooldown == 0 and _detect_stagnation(history)
        ab_chosen = None

        if stagnated:
            worker_buf.append(
                f"[yellow bold]🔀 정체 감지 ({STAGNATION_THRESHOLD}회 연속) "
                f"— 전략 A/B 분기 시작[/yellow bold]"
            )
            refresh("worker", iteration)
            ab_output, ab_chosen = _run_ab_strategy(
                goal, history, workdir,
                worker_model, worker_sys, active_tools,
                eval_model, past_attempts,
                worker_buf, iteration, refresh,
            )
            if ab_chosen == "interrupted":
                live.stop()
                _last_session = {"goal": goal, "history": history,
                                 "eval_history": eval_history, "workdir": workdir}
                _persist_session(_last_session)
                return _finish('interrupted')
            last_msg = ab_output
            ab_cooldown = STAGNATION_THRESHOLD  # A/B 직후 N회는 재발동 억제
        else:
            # 일반 Worker 실행
            worker_prompt = build_worker_prompt(goal, history, past_attempts=past_attempts,
                                                session_context=session_context)
            worker_result = [None, None]

            def _worker():
                worker_result[0], worker_result[1] = run_worker(
                    worker_prompt, workdir, worker_model, worker_buf, worker_status,
                    system_prompt=worker_sys, tools=active_tools)

            t = threading.Thread(target=_worker, daemon=True)
            t.start()
            while t.is_alive():
                if _interrupt_event.is_set():
                    break
                refresh("worker", iteration)
                time.sleep(0.1)
            t.join(timeout=10)
            refresh("worker", iteration)

            if _interrupt_event.is_set():
                _cp_delete(cp_before)
                live.stop()
                _last_session = {"goal": goal, "history": history,
                                 "eval_history": eval_history, "workdir": workdir}
                _persist_session(_last_session)
                return _finish('interrupted')

            last_msg, _ = worker_result

        last_msg_str = last_msg or ""
        worker_summary = last_msg_str.replace('\n', ' ')[:300]
        hypothesis = _extract_hypothesis(last_msg_str)
        history.append({
            'iter': iteration,
            'worker_summary': worker_summary,
            'worker_lines': list(worker_buf)[-12:],
            'decision': '',
            'feedback': '',
            **({"ab_chosen": ab_chosen} if ab_chosen else {}),
        })

        # ── 백그라운드 학습 job 감지 ─────────────────────────────────────
        pid_m = _BG_PID_RE.search(last_msg_str)
        log_m = _BG_LOG_RE.search(last_msg_str)
        if pid_m and log_m and bg_train is None:
            bg_pid = int(pid_m.group(1))
            with _active_procs_lock:
                bg_proc = next((p for p in _active_procs if p.pid == bg_pid), None)
            bg_train = {
                "pid": bg_pid,
                "log_path": log_m.group(1).strip(),
                "proc": bg_proc,
                "started_at": time.time(),
                "last_poll_at": time.time(),
                "poll_count": 0,
            }
            worker_buf.append(f"[cyan]📊 학습 모니터 시작: PID {bg_pid}[/cyan]")
            refresh("worker", iteration)

        # ── 학습 모니터링 루프 ────────────────────────────────────────────
        if bg_train is not None:
            monitor_result = _run_monitor_loop(
                bg_train, goal, workdir, eval_model, train_poll_seconds,
                layout, live, worker_buf, eval_history, iteration, refresh,
            )
            if monitor_result == "DONE":
                done = True
                refresh("done", iteration)
                time.sleep(0.8)
                live.stop()
                _last_session = {
                    "goal": goal, "history": history,
                    "eval_history": eval_history, "workdir": workdir,
                }
                _persist_session(_last_session)
                console.print()
                console.print(Rule(f"[bold green]✓ 학습 완료 — {iteration}번 반복[/bold green]"))
                return _finish('done')
            elif monitor_result.startswith("KILL:"):
                kill_reason = monitor_result[5:]
                history[-1]['decision'] = 'REDIRECT'
                history[-1]['feedback'] = f"학습 중단({kill_reason}). 다른 접근 시도."
                eval_history.append({
                    'iter': iteration,
                    'decision': 'REDIRECT',
                    'feedback': f"학습 중단: {kill_reason}",
                    'full_msg': f"KILL:{kill_reason}",
                })
                bg_train = None
                continue  # 다음 iteration → Worker가 REDIRECT 보고 새 전략 시도
            elif monitor_result == "interrupted":
                bg_train = None
                live.stop()
                _last_session = {
                    "goal": goal, "history": history,
                    "eval_history": eval_history, "workdir": workdir,
                }
                _persist_session(_last_session)
                return _finish('interrupted')
            else:  # "natural_exit"
                bg_train = None
                # 프로세스가 자연 종료 → 결과 평가로 계속 진행

        # ── Evaluator ────────────────────────────────────────────────────
        if _interrupt_event.is_set():
            live.stop()
            _last_session = {"goal": goal, "history": history,
                             "eval_history": eval_history, "workdir": workdir}
            _persist_session(_last_session)
            return _finish('interrupted')

        if iteration % eval_every == 0 or iteration == max_iter:
            refresh("evaluator", iteration)
            eval_prompt = build_evaluator_prompt(goal, last_msg or "", iteration, workdir,
                                                 past_attempts=past_attempts,
                                                 history=history)
            eval_msg, _ = run_evaluator(eval_prompt, workdir, eval_model,
                                        system_prompt=eval_sys)
        else:
            eval_msg = "IMPROVE: (evaluation skipped)"

        decision, feedback = parse_decision(eval_msg)
        history[-1]['decision'] = decision
        history[-1]['feedback'] = feedback
        eval_history.append({
            'iter': iteration,
            'decision': decision,
            'feedback': feedback,
            'full_msg': eval_msg,
        })

        # ── 체크포인트 처리 ───────────────────────────────────────────────
        if decision == 'REDIRECT' and cp_before is not None:
            # REDIRECT: 이번 iteration 변경사항 롤백
            restored = _cp_restore(workdir, cp_before)
            if restored:
                worker_buf.append("[yellow]↩ REDIRECT — 변경사항 롤백됨[/yellow]")
            _cp_delete(cp_before)
        else:
            # DONE/IMPROVE: 변경사항 유지, 체크포인트 파일만 삭제
            _cp_delete(cp_before)

        # ── 지식 저장소에 attempt 기록 ───────────────────────────────────
        attempt_record = {
            "timestamp": time.strftime("%Y-%m-%dT%H:%M:%S"),
            "iter": iteration,
            "decision": decision,
            "feedback": feedback,
            "worker_summary": worker_summary,
            "hypothesis": hypothesis,
            "goal": goal,
        }
        _save_attempt(goal, attempt_record)
        past_attempts.append(attempt_record)  # 현재 세션 내 즉시 반영
        _write_report_entry(goal, iteration, decision, feedback, worker_summary, hypothesis)

        # ── 이전 압축 결과 반영 ──────────────────────────────────────────
        if _compress_thread and not _compress_thread.is_alive() and _compress_result:
            history = _compress_result[0]
            _compress_result.clear()
            _compress_thread = None

        # ── 프롬프트 토큰이 100k 초과 시 백그라운드 압축 시작 ────────────
        prompt_tokens = _estimate_tokens(build_worker_prompt(goal, history, past_attempts=past_attempts))
        if (prompt_tokens > TOKEN_COMPRESS_THRESHOLD
                and (_compress_thread is None or not _compress_thread.is_alive())
                and decision != 'DONE'):
            _snap = list(history)  # 스냅샷 캡처
            _res  = _compress_result

            def _do_compress():
                new_h = compress_history(_snap, goal, eval_model)
                _res.clear()
                _res.append(new_h)

            _compress_thread = threading.Thread(target=_do_compress, daemon=True)
            _compress_thread.start()

        if decision == 'DONE':
            done = True
            refresh("done", iteration)
            time.sleep(0.8)
            live.stop()
            _last_session = {
                "goal": goal, "history": history,
                "eval_history": eval_history, "workdir": workdir,
            }
            _persist_session(_last_session)

            # 완료 요약 출력
            console.print()
            console.print(Rule(f"[bold green]✓ 완료 — {iteration}번 반복[/bold green]"))
            console.print()
            for section, color in [('판단 이유', 'white'), ('결과물 위치', 'cyan'), ('결과 요약', 'bright_white')]:
                m = re.search(rf'{section}:\s*(.+?)(?=\n판단|결과물|결과 요약|\Z)', eval_msg, re.S)
                if m:
                    val = m.group(1).strip()
                    console.print(f"[bold]{section}[/bold]")
                    for line in val.splitlines():
                        console.print(f"  [{color}]{line}[/{color}]")
                    console.print()
            # 실험 결과 자동 시각화
            plots = _try_visualize(workdir, goal)
            if plots:
                console.print(f"[dim]📊 학습 결과 시각화 — {len(plots)}개 플롯 생성됨[/dim]")
                for p in plots:
                    console.print(f"  [cyan]{p}[/cyan]")
                console.print()
            # 리포트 위치 안내
            report_path = _knowledge_path(goal) / "report.md"
            if report_path.exists():
                console.print(f"[dim]📝 실험 리포트: {report_path}[/dim]")
                console.print(f"[dim]   확인: /report[/dim]")
                console.print()
            return _finish('done')

    live.stop()
    _last_session = {
        "goal": goal, "history": history,
        "eval_history": eval_history, "workdir": workdir,
    }
    _persist_session(_last_session)
    return _finish('max')


def run_dual_agent_loop(
    goal: str, task_a: str, task_b: str,
    workdir: str, worker_model: str | None, eval_model: str | None,
    max_iter: int, layout: Layout, live: Live,
    initial_history1=None, initial_history2=None,
    initial_eval_history1=None, initial_eval_history2=None,
    mode: str = "code", eval_every: int = 1,
    session_context: list | None = None,
) -> str:
    """
    Dual Worker + Dual Evaluator 병렬 루프.
    반환: 'done' | 'max' | 'interrupted'
    """
    global _last_session
    history1 = list(initial_history1 or [])
    history2 = list(initial_history2 or [])
    eval_history1 = list(initial_eval_history1 or [])
    eval_history2 = list(initial_eval_history2 or [])
    buf1 = deque(maxlen=WORKER_BUF_LINES)
    buf2 = deque(maxlen=WORKER_BUF_LINES)
    status1 = ["idle"]
    status2 = ["idle"]
    _session_start = time.time()   # 세션 시작 시각
    done1 = False
    done2 = False
    current_task_a = task_a
    current_task_b = task_b

    worker_sys = RESEARCH_WORKER_SYSTEM if mode == "research" else WORKER_SYSTEM
    active_tools = (RESEARCH_TOOLS if mode == "research" else WORKER_TOOLS) + _mcp_all_tools()

    past_attempts1 = _load_past_attempts(task_a)
    past_attempts2 = _load_past_attempts(task_b)
    _sim1 = _find_similar_goals(task_a, threshold=0.6)
    _sim2 = _find_similar_goals(task_b, threshold=0.6)
    def _rag_line(attempts, sim_dirs):
        if attempts:
            if sim_dirs:
                return (f"[dim]📚 RAG: {len(attempts)}개 시도"
                        f" ([cyan]+{len(sim_dirs)}개 유사 병합[/cyan])[/dim]")
            return f"[dim]📚 RAG: {len(attempts)}개 과거 시도 (exact)[/dim]"
        return "[dim]📚 RAG: 매칭 없음[/dim]"
    _rag_note = _rag_line(past_attempts1 or past_attempts2,
                          _sim1 + [d for d in _sim2 if d not in _sim1])

    def _finish(result: str) -> str:
        return result

    # ── DEBUG: 로그 파일 경로 설정 (agentforge 실행 위치에 생성) ───────────────
    global _DEBUG_LOG_PATH
    _DEBUG_LOG_PATH = str(Path(workdir) / f"agentforge_debug_{_dt.datetime.now().strftime('%Y%m%d_%H%M%S')}.log")
    _dbg("LOOP", f"SESSION_START  mode=dual  workdir={workdir}  goal={goal[:80]}")
    _dbg("LOOP", f"TASK_A={task_a[:80]}")
    _dbg("LOOP", f"TASK_B={task_b[:80]}")
    # ── END DEBUG ────────────────────────────────────────────────────────────

    def _persist_dual():
        global _last_session
        _last_session = {
            "mode": "dual", "goal": goal,
            "task_a": current_task_a, "task_b": current_task_b,
            "history1": history1, "history2": history2,
            "eval_history1": eval_history1, "eval_history2": eval_history2,
            "workdir": workdir,
        }
        _persist_session(_last_session)

    def refresh(phase: str, iteration: int):
        layout["header"].update(render_header(goal, iteration, max_iter, phase, _rag_note, _session_start))
        layout["summary_bar"].update(
            render_summary_bar(current_task_a, current_task_b, status1[0], status2[0])
        )
        layout["worker1"].update(
            render_worker_panel(buf1, iteration, status1[0], history1, done1, label="WORKER 1")
        )
        layout["worker2"].update(
            render_worker_panel(buf2, iteration, status2[0], history2, done2, label="WORKER 2")
        )
        layout["evaluator"].update(
            render_dual_evaluator_panel(eval_history1, eval_history2, iteration, phase, done1, done2)
        )
        layout["cmd_bar"].update(
            render_cmd_bar(buf1, buf2, status1[0], status2[0])
        )

    # 이전 레이아웃 잔상 제거 후 즉시 듀얼 레이아웃 시작
    console.clear()
    if not live._started:
        live.start()
    refresh("idle", 0)

    for iteration in range(1, max_iter + 1):
        # ── DEBUG: 이터레이션 시작 ────────────────────────────────────────
        _dbg("LOOP", f"ITER_START  iteration={iteration}  done1={done1}  done2={done2}")
        _iter_t0 = time.time()
        # ── END DEBUG ────────────────────────────────────────────────────
        if done1 and done2:
            break

        # ── Phase 1: Workers 병렬 실행 ───────────────────────────────────
        buf1.clear()
        buf2.clear()
        if not done1:
            status1[0] = "running"
        if not done2:
            status2[0] = "running"

        refresh("dual_worker", iteration)

        w1_result: list = [None, None]
        w2_result: list = [None, None]

        def _w1():
            if done1:
                return
            prompt = build_worker_prompt(current_task_a, history1, past_attempts=past_attempts1,
                                         session_context=session_context)
            w1_result[0], w1_result[1] = run_worker(
                prompt, workdir, worker_model, buf1, status1,
                system_prompt=worker_sys, tools=active_tools, worker_id=1)

        def _w2():
            if done2:
                return
            prompt = build_worker_prompt(current_task_b, history2, past_attempts=past_attempts2,
                                         session_context=session_context)
            w2_result[0], w2_result[1] = run_worker(
                prompt, workdir, worker_model, buf2, status2,
                system_prompt=worker_sys, tools=active_tools, worker_id=2)

        t1 = threading.Thread(target=_w1, daemon=True)
        t2 = threading.Thread(target=_w2, daemon=True)
        if not done1:
            t1.start()
        if not done2:
            t2.start()

        while (not done1 and t1.is_alive()) or (not done2 and t2.is_alive()):
            if _interrupt_event.is_set():
                break
            refresh("dual_worker", iteration)
            time.sleep(0.1)

        if not done1:
            t1.join(timeout=10)
        if not done2:
            t2.join(timeout=10)
        refresh("dual_worker", iteration)

        if _interrupt_event.is_set():
            live.stop()
            _persist_dual()
            return _finish('interrupted')

        # Worker 출력 수집
        msg1 = w1_result[0] or "" if not done1 else "(W1 이미 완료)"
        msg2 = w2_result[0] or "" if not done2 else "(W2 이미 완료)"
        summary1 = msg1.replace('\n', ' ')[:300]
        summary2 = msg2.replace('\n', ' ')[:300]

        if not done1:
            history1.append({
                'iter': iteration, 'worker_summary': summary1,
                'worker_lines': list(buf1)[-12:], 'decision': '', 'feedback': '',
            })
        if not done2:
            history2.append({
                'iter': iteration, 'worker_summary': summary2,
                'worker_lines': list(buf2)[-12:], 'decision': '', 'feedback': '',
            })

        # ── Phase 2: Evaluators 병렬 실행 ────────────────────────────────
        refresh("dual_evaluator", iteration)

        eval1_result: list = [None, None]
        eval2_result: list = [None, None]

        def _e1():
            if done1:
                return
            ep = build_evaluator_prompt(current_task_a, msg1, iteration, workdir,
                                        past_attempts=past_attempts1, history=history1)
            eval1_result[0], eval1_result[1] = run_evaluator(
                ep, workdir, eval_model, system_prompt=DUAL_EVALUATOR_SYSTEM)

        def _e2():
            if done2:
                return
            ep = build_evaluator_prompt(current_task_b, msg2, iteration, workdir,
                                        past_attempts=past_attempts2, history=history2)
            eval2_result[0], eval2_result[1] = run_evaluator(
                ep, workdir, eval_model, system_prompt=DUAL_EVALUATOR_SYSTEM)

        et1 = threading.Thread(target=_e1, daemon=True)
        et2 = threading.Thread(target=_e2, daemon=True)
        if not done1:
            et1.start()
        if not done2:
            et2.start()

        while (not done1 and et1.is_alive()) or (not done2 and et2.is_alive()):
            if _interrupt_event.is_set():
                break
            refresh("dual_evaluator", iteration)
            time.sleep(0.1)

        if not done1:
            et1.join(timeout=10)
        if not done2:
            et2.join(timeout=10)

        if _interrupt_event.is_set():
            live.stop()
            _persist_dual()
            return _finish('interrupted')

        # ── Phase 3: Decision 처리 ────────────────────────────────────────
        eval_msg1 = eval1_result[0] or "IMPROVE: (no response)" if not done1 else ""
        eval_msg2 = eval2_result[0] or "IMPROVE: (no response)" if not done2 else ""

        decision1, feedback1 = parse_decision(eval_msg1) if not done1 else ("DONE", "")
        decision2, feedback2 = parse_decision(eval_msg2) if not done2 else ("DONE", "")

        if not done1:
            history1[-1]['decision'] = decision1
            history1[-1]['feedback'] = feedback1
            eval_history1.append({
                'iter': iteration, 'decision': decision1,
                'feedback': feedback1, 'full_msg': eval_msg1,
            })
        if not done2:
            history2[-1]['decision'] = decision2
            history2[-1]['feedback'] = feedback2
            eval_history2.append({
                'iter': iteration, 'decision': decision2,
                'feedback': feedback2, 'full_msg': eval_msg2,
            })

        refresh("dual_evaluator", iteration)

        # GPU_PICK 처리
        if decision1 == 'GPU_PICK' or decision2 == 'GPU_PICK':
            rw = 2 if decision2 == 'GPU_PICK' else 1
            live.stop()

            gpu_list = _list_all_gpus()
            console.print(Rule(f"[yellow]Worker {rw} — GPU 선택 필요[/yellow]"))
            reason = feedback2 if rw == 2 else feedback1
            console.print(f"[yellow]평가자 판단:[/yellow] {reason}\n")
            for i, g in enumerate(gpu_list, 1):
                w1_tag = " [dim](Worker 1 사용 중)[/dim]" if _ACTIVE_GPU.get(1) == g['id'] else ""
                bar = "█" * int(g['util'] * 10) + "░" * (10 - int(g['util'] * 10))
                console.print(
                    f"  [[cyan]{i}[/cyan]] GPU {g['id']} {g['name'][:20]}"
                    f"  {g['used_mb']:.0f}/{g['total_mb']:.0f}MB  [{bar}] {g['util']*100:.0f}%"
                    f"{w1_tag}"
                )
            console.print(f"  [[cyan]0[/cyan]] 다른 명령 내리기")
            console.print()

            try:
                choice_str = PromptSession(style=PROMPT_STYLE).prompt(
                    HTML('<ansiyellow>선택 (번호)</ansiyellow> <ansiwhite>></ansiwhite> ')
                ).strip()
                choice = int(choice_str)
            except (ValueError, EOFError, KeyboardInterrupt):
                choice = -1

            if choice == 0:
                try:
                    user_instruction = PromptSession(style=PROMPT_STYLE).prompt(
                        HTML(f'<ansicyan>Worker {rw} 에게 내릴 명령</ansicyan> '
                             f'<ansiwhite>></ansiwhite> ')
                    ).strip()
                except (EOFError, KeyboardInterrupt):
                    user_instruction = ""
                if user_instruction:
                    target_task = current_task_b if rw == 2 else current_task_a
                    override_prompt = (
                        f"User override instruction for Worker {rw}: {user_instruction}\n"
                        f"Worker's previous task: {target_task}\n"
                        f"Based on this user instruction, issue an IMPROVE or REDIRECT decision "
                        f"to guide the worker on what to do next."
                    )
                    override_eval_msg, _ = run_evaluator(
                        override_prompt, workdir, eval_model,
                        system_prompt=DUAL_EVALUATOR_SYSTEM)
                    ov_decision, ov_feedback = parse_decision(override_eval_msg)
                    target_hist = history2 if rw == 2 else history1
                    if target_hist:
                        target_hist[-1]['decision'] = ov_decision
                        target_hist[-1]['feedback'] = ov_feedback
                    target_eval_hist = eval_history2 if rw == 2 else eval_history1
                    target_eval_hist.append({
                        'iter': iteration, 'decision': ov_decision,
                        'feedback': ov_feedback, 'full_msg': override_eval_msg,
                    })
                else:
                    live.start()
                    _persist_dual()
                    continue

            elif 1 <= choice <= len(gpu_list):
                selected_gpu = gpu_list[choice - 1]['id']
                with _ACTIVE_GPU_LOCK:
                    _ACTIVE_GPU[rw] = selected_gpu
                target_hist = history2 if rw == 2 else history1
                if target_hist:
                    target_hist[-1]['decision'] = 'REDIRECT'
                    target_hist[-1]['feedback'] = f"GPU {selected_gpu}(으)로 재시도"
                target_eval_hist = eval_history2 if rw == 2 else eval_history1
                target_eval_hist.append({
                    'iter': iteration, 'decision': 'REDIRECT',
                    'feedback': f"사용자 선택: GPU {selected_gpu}",
                    'full_msg': f"GPU_PICK resolved: GPU {selected_gpu}",
                })

            live.start()
            refresh("idle", iteration)
            _persist_dual()
            continue

        # DONE 처리
        if decision1 == 'DONE' and not done1:
            done1 = True
            buf1.append("[green bold]✓ W1 완료[/green bold]")
        if decision2 == 'DONE' and not done2:
            done2 = True
            buf2.append("[green bold]✓ W2 완료[/green bold]")

        refresh("dual_evaluator", iteration)

        # RAG 기록
        if not done1 or history1 and history1[-1].get('decision'):
            _save_attempt(current_task_a, {
                "timestamp": time.strftime("%Y-%m-%dT%H:%M:%S"),
                "iter": iteration, "decision": decision1, "feedback": feedback1,
                "worker_summary": summary1, "goal": current_task_a,
            })
        if not done2 or history2 and history2[-1].get('decision'):
            _save_attempt(current_task_b, {
                "timestamp": time.strftime("%Y-%m-%dT%H:%M:%S"),
                "iter": iteration, "decision": decision2, "feedback": feedback2,
                "worker_summary": summary2, "goal": current_task_b,
            })

        _persist_dual()

        if done1 and done2:
            time.sleep(0.8)
            live.stop()
            console.print()
            console.print(Rule(f"[bold green]✓ 듀얼 완료 — {iteration}번 반복[/bold green]"))
            console.print(f"[cyan]W1:[/cyan] {current_task_a[:60]}")
            console.print(f"[cyan]W2:[/cyan] {current_task_b[:60]}")
            return _finish('done')

    live.stop()
    _persist_dual()
    if done1 and done2:
        return _finish('done')
    return _finish('max')


# ── Interrupt Handler ─────────────────────────────────────────────────────────

def _handle_interrupt(goal: str, workdir: str, args, max_iter: int) -> str:
    """
    ESC 중단 후 목표 편집 프롬프트 표시.
    새 목표로 루프를 재실행하고, 최종 목표 문자열 반환.
    """
    console.print(
        "\n[yellow]⚠  중단됨.[/yellow] "
        "목표를 수정하거나 Enter로 재실행, Ctrl+C로 REPL 복귀:"
    )
    try:
        new_goal = PromptSession(style=PROMPT_STYLE).prompt(
            HTML('<ansiyellow><b>목표 수정</b></ansiyellow> <ansiwhite>></ansiwhite> '),
            default=goal,
        ).strip()
    except (EOFError, KeyboardInterrupt):
        console.print("[dim]취소됨. REPL로 돌아갑니다.[/dim]")
        return goal

    if not new_goal:
        new_goal = goal  # Enter만 누르면 동일 목표 재실행

    layout2 = make_layout()
    layout2["header"].update(render_header(new_goal, 0, max_iter, "idle"))
    layout2["worker"].update(render_worker_panel(deque(), 0, "idle", [], False))
    layout2["evaluator"].update(render_evaluator_panel([], 0, "idle", False))
    layout2["cmd_bar"].update(render_cmd_bar(deque(), deque(), "idle", "idle"))
    live2 = Live(layout2, refresh_per_second=8, screen=False)

    # 목표가 바뀌면 히스토리 없이 fresh 실행
    outcome = run_agent_loop(
        new_goal, workdir, args.worker_model, args.eval_model,
        max_iter, layout2, live2,
    )
    if outcome == 'interrupted':
        return _handle_interrupt(new_goal, workdir, args, max_iter)
    elif outcome == 'max':
        console.print(f"[red]{max_iter}번 반복 후에도 완료되지 않았습니다.[/red]")
    console.print("[dim]다음 명령을 입력하세요. /exit 로 종료.[/dim]")
    return new_goal


# ── Main ──────────────────────────────────────────────────────────────────────

def main():
    # ── tmux 자동 래핑 ─────────────────────────────────────────────────
    # -r / --reconnect: 기존 세션 재접속
    if len(sys.argv) >= 2 and sys.argv[1] in ("-r", "--reconnect"):
        _tmux_reconnect()
        return

    # --new-session: 기존 세션 무시하고 강제로 새 세션
    force_new = len(sys.argv) >= 2 and sys.argv[1] == "--new-session"
    extra_args = [a for a in sys.argv[1:] if a != "--new-session"]

    if not _in_tmux() and _shutil.which("tmux"):
        if force_new and _tmux_session_exists():
            subprocess.run(["tmux", "kill-session", "-t", TMUX_SESSION])
        _tmux_launch(extra_args)
        # execvp 실패 또는 세션 이미 존재 시 여기까지 옴 → 일반 모드로 계속

    parser = argparse.ArgumentParser(
        prog="agentforge",
        description="Worker + Evaluator 인터랙티브 멀티에이전트 CLI",
    )
    sub = parser.add_subparsers(dest="subcommand")

    auth_parser = sub.add_parser("auth", help="인증 관리 (ChatGPT Plus/Pro)")
    auth_sub = auth_parser.add_subparsers(dest="auth_cmd")

    login_parser = auth_sub.add_parser("login", help="로그인")
    login_parser.add_argument("--device", action="store_true",
        help="SSH/헤드리스 환경용 device auth 사용")
    auth_sub.add_parser("logout", help="로그아웃")
    auth_sub.add_parser("status", help="현재 인증 상태 확인")

    parser.add_argument("-d", "--dir", default=".", metavar="DIR",
                        help="작업 디렉토리 (기본: 현재 디렉토리)")
    parser.add_argument("--worker-model", default=None, metavar="MODEL",
                        help="Worker 모델")
    parser.add_argument("--eval-model", default=None, metavar="MODEL",
                        help="Evaluator 모델")
    parser.add_argument("-n", "--max-iterations", type=int, default=DEFAULT_MAX_ITER,
                        metavar="N", help=f"최대 반복 횟수 (기본: {DEFAULT_MAX_ITER})")
    parser.add_argument("--mode", choices=["code", "research"], default="code",
                        help="실행 모드: code(기본) / research(웹 검색·분석)")
    parser.add_argument("--eval-every", type=int, default=1, metavar="N",
                        help="N번 반복마다 Evaluator 실행 (기본: 1, 즉 매번)")
    args = parser.parse_args()

    # ── auth 서브커맨드 ────────────────────────────────────────────────
    if args.subcommand == "auth":
        if not CODEX_BIN.exists():
            console.print(f"[red]Error: codex not found at {CODEX_BIN}[/red]")
            sys.exit(1)
        if args.auth_cmd == "login":
            cmd_auth_login(device=getattr(args, "device", False))
        elif args.auth_cmd == "logout":
            cmd_auth_logout()
        elif args.auth_cmd == "status":
            cmd_auth_status()
        else:
            auth_parser.print_help()
        return

    workdir = str(Path(args.dir).resolve())
    max_iter = args.max_iterations

    # ── 초기 TUI 표시 ─────────────────────────────────────────────────
    layout = make_layout()
    layout["header"].update(render_header("", 0, max_iter, "idle"))
    layout["worker"].update(render_worker_panel(deque(), 0, "idle", [], False))
    layout["evaluator"].update(render_evaluator_panel([], 0, "idle", False))
    layout["cmd_bar"].update(render_cmd_bar(deque(), deque(), "idle", "idle"))
    with Live(layout, refresh_per_second=8, screen=False) as live:
        time.sleep(0.3)

    # ── REPL 루프 ─────────────────────────────────────────────────────
    status = auth_status()
    if not status or not status["has_token"]:
        console.print(
            "[yellow]⚠  로그인되지 않았습니다.[/yellow] "
            "지금 로그인하시겠습니까? ([bold]y[/bold]/n/device) ",
            end="",
        )
        try:
            ans = input().strip().lower()
        except (EOFError, KeyboardInterrupt):
            ans = "n"
        if ans in ("y", ""):
            cmd_auth_login(device=False)
        elif ans == "device":
            cmd_auth_login(device=True)
        else:
            console.print(
                "[dim]로그인을 건너뜁니다. "
                "agentforge auth login 으로 나중에 로그인할 수 있습니다.[/dim]"
            )

    global _last_session
    current_mode = args.mode
    eval_every   = args.eval_every
    # _last_session은 /resume 시점에 디스크에서 로드 (기본은 항상 새 시작)
    # 같은 REPL 세션에서 완료된 목표들의 요약 컨텍스트
    _session_summaries: list[dict] = []

    # MCP 서버 초기화
    _mcp_init()
    if _MCP_REGISTRY:
        tool_names = [t["name"] for c in _MCP_REGISTRY.values() for t in c.tools]
        console.print(f"[dim]🔌 MCP 서버 {len(_MCP_REGISTRY)}개 연결됨 — 툴: {', '.join(tool_names[:6])}{'...' if len(tool_names)>6 else ''}[/dim]")
    import atexit
    atexit.register(_mcp_stop_all)

    console.print(f"[dim]명령을 입력하세요. /help 로 커맨드 목록 확인. 모드: {current_mode}[/dim]")

    _completer = SlashCompleter()
    _session = PromptSession(
        completer=_completer,
        complete_while_typing=True,
        style=PROMPT_STYLE,
    )

    while True:
        try:
            raw = _session.prompt(
                HTML('<ansicyan><b>[agentforge]</b></ansicyan> <ansiwhite>></ansiwhite> '),
            ).strip()
        except (EOFError, KeyboardInterrupt):
            console.print("\n[dim]종료합니다.[/dim]")
            break

        if not raw:
            continue

        # 슬래시 커맨드 처리
        if raw.startswith('/'):
            token = raw[1:].split(None, 1)
            cmd_name = token[0].lower() if token else ''
            cmd_arg = token[1] if len(token) > 1 else ''

            if cmd_name == 'exit':
                console.print("[dim]종료합니다.[/dim]")
                break

            elif cmd_name == 'resume':
                if not _last_session:
                    # 이번 실행에서 아직 세션이 없으면 디스크에서 로드 시도
                    _last_session = _load_persisted_session()
                if not _last_session:
                    console.print("[yellow]재개할 세션이 없습니다. 먼저 목표를 실행하세요.[/yellow]")
                    continue
                s = _last_session
                saved_at = s.get('saved_at', '알 수 없음')
                console.print(Rule("[cyan]세션 재개[/cyan]"))
                console.print(f"[dim]목표:[/dim]    [white]{s['goal'][:80]}[/white]")
                console.print(f"[dim]저장:[/dim]    {saved_at}")
                console.print()
                if s.get("mode") == "dual":
                    prev_iters = max(len(s.get("history1", [])), len(s.get("history2", [])))
                    console.print(f"[dim]반복:[/dim]    {prev_iters}회 완료 (듀얼 모드)")
                    console.print(f"[dim]W1 task:[/dim] {s.get('task_a', '')[:60]}")
                    console.print(f"[dim]W2 task:[/dim] {s.get('task_b', '')[:60]}")
                    console.print()
                    layout2 = make_dual_layout()
                    layout2["header"].update(render_header(s["goal"], prev_iters, max_iter, "idle"))
                    layout2["summary_bar"].update(render_summary_bar(
                        s.get("task_a", ""), s.get("task_b", ""), "idle", "idle"))
                    layout2["worker1"].update(render_worker_panel(
                        deque(), prev_iters, "idle", s.get("history1", []), False, label="WORKER 1"))
                    layout2["worker2"].update(render_worker_panel(
                        deque(), prev_iters, "idle", s.get("history2", []), False, label="WORKER 2"))
                    layout2["evaluator"].update(render_dual_evaluator_panel(
                        s.get("eval_history1", []), s.get("eval_history2", []),
                        prev_iters, "idle", False, False))
                    layout2["cmd_bar"].update(render_cmd_bar(deque(), deque(), "idle", "idle"))
                    live2 = Live(layout2, refresh_per_second=8, screen=False)
                    outcome = run_dual_agent_loop(
                        s["goal"], s.get("task_a", s["goal"]), s.get("task_b", s["goal"]),
                        s["workdir"], args.worker_model, args.eval_model,
                        max_iter, layout2, live2,
                        initial_history1=s.get("history1"),
                        initial_history2=s.get("history2"),
                        initial_eval_history1=s.get("eval_history1"),
                        initial_eval_history2=s.get("eval_history2"),
                        mode=current_mode, eval_every=eval_every,
                    )
                else:
                    prev_iters = len(s.get("history", []))
                    console.print(f"[dim]반복:[/dim]    {prev_iters}회 완료")
                    last_decision = next(
                        (h['decision'] for h in reversed(s.get('history', []))
                         if h.get('decision') and h.get('type') != 'compressed_summary'),
                        '없음'
                    )
                    console.print(f"[dim]마지막 판정:[/dim] {last_decision}")
                    console.print()
                    layout2 = make_layout()
                    layout2["header"].update(render_header(s["goal"], prev_iters, max_iter, "idle"))
                    layout2["worker"].update(render_worker_panel(deque(), prev_iters, "idle", s["history"], False))
                    layout2["evaluator"].update(render_evaluator_panel(s["eval_history"], prev_iters, "idle", False))
                    layout2["cmd_bar"].update(render_cmd_bar(deque(), deque(), "idle", "idle"))
                    live2 = Live(layout2, refresh_per_second=8, screen=False)
                    outcome = run_agent_loop(
                        s["goal"], s["workdir"],
                        args.worker_model, args.eval_model,
                        max_iter, layout2, live2,
                        initial_history=s["history"],
                        initial_eval_history=s["eval_history"],
                        mode=current_mode, eval_every=eval_every,
                    )
                if outcome == 'interrupted':
                    console.print("\n[yellow]⚠  중단됨. REPL로 돌아갑니다.[/yellow]")
                elif outcome == 'max':
                    console.print(f"[red]{max_iter}번 반복 후에도 완료되지 않았습니다.[/red]")
                if outcome != 'interrupted':
                    console.print("[dim]다음 명령을 입력하세요. /exit 로 종료.[/dim]")

            elif cmd_name == 'mode':
                if cmd_arg in ('code', 'research', 'dual', 'single'):
                    current_mode = 'code' if cmd_arg == 'single' else cmd_arg
                    # 모드 변경 시 화면 즉시 갱신
                    console.clear()
                    if current_mode == 'dual':
                        _il = make_dual_layout()
                        _il["header"].update(render_header("", 0, max_iter, "idle"))
                        _il["summary_bar"].update(render_summary_bar("", "", "idle", "idle"))
                        _il["worker1"].update(render_worker_panel(deque(), 0, "idle", [], False, label="WORKER 1"))
                        _il["worker2"].update(render_worker_panel(deque(), 0, "idle", [], False, label="WORKER 2"))
                        _il["evaluator"].update(render_dual_evaluator_panel([], [], 0, "idle", False, False))
                        _il["cmd_bar"].update(render_cmd_bar(deque(), deque(), "idle", "idle"))
                    else:
                        _il = make_layout()
                        _il["header"].update(render_header("", 0, max_iter, "idle"))
                        _il["worker"].update(render_worker_panel(deque(), 0, "idle", [], False))
                        _il["evaluator"].update(render_evaluator_panel([], 0, "idle", False))
                        _il["cmd_bar"].update(render_cmd_bar(deque(), deque(), "idle", "idle"))
                    with Live(_il, refresh_per_second=4, screen=False):
                        time.sleep(0.1)
                    console.print(f"[cyan]모드 변경: {current_mode}[/cyan]")
                    if current_mode == 'dual':
                        console.print("[dim]Dual 모드: Coordinator가 목표를 W1/W2로 분기합니다.[/dim]")
                    console.print(f"[dim]명령을 입력하세요. 모드: {current_mode}[/dim]")
                else:
                    console.print("[red]/mode code|research|dual|single[/red]")

            elif cmd_name == 'eval-every':
                try:
                    n = int(cmd_arg)
                    if n < 1:
                        raise ValueError
                    eval_every = n
                    console.print(f"[cyan]Evaluator: {eval_every}번마다 실행[/cyan]")
                except ValueError:
                    console.print("[red]1 이상의 숫자를 입력하세요. 예: /eval-every 3[/red]")

            elif cmd_name == 'dir':
                if not cmd_arg:
                    console.print(f"현재 작업 디렉토리: [cyan]{workdir}[/cyan]")
                    console.print("[dim]변경: /dir <경로>  예) /dir ~/AgentForge[/dim]")
                else:
                    new_dir = Path(cmd_arg).expanduser().resolve()
                    if not new_dir.exists():
                        console.print(f"[red]존재하지 않는 경로: {new_dir}[/red]")
                    elif not new_dir.is_dir():
                        console.print(f"[red]디렉토리가 아닙니다: {new_dir}[/red]")
                    else:
                        workdir = str(new_dir)
                        console.print(f"[cyan]작업 디렉토리 변경: {workdir}[/cyan]")

            elif cmd_name == 'status':
                wandb_str = f"[green]✓ 연동됨[/green]" if _WANDB_API_KEY else "[yellow]미연동[/yellow]"
                console.print(
                    f"모드: [cyan]{current_mode}[/cyan]  |  "
                    f"eval-every: [cyan]{eval_every}[/cyan]  |  "
                    f"dir: [cyan]{workdir}[/cyan]  |  "
                    f"wandb: {wandb_str}"
                )

            elif cmd_name == 'wandb':
                _wandb_status()

            elif cmd_name == 'report':
                _print_report(goal if 'goal' in dir() else "")

            elif cmd_name == 'paper':
                if not cmd_arg:
                    console.print("[red]사용법: /paper <url>  예) /paper https://arxiv.org/abs/2312.xxxxx[/red]")
                else:
                    paper_goal = _fetch_paper_and_extract(cmd_arg, args.eval_model)
                    if not paper_goal:
                        console.print("[red]논문 분석 실패. URL을 확인하거나 직접 목표를 입력하세요.[/red]")
                    else:
                        short = paper_goal.split('\n')[0][:80]
                        console.print(f"[green]✓ 논문 분석 완료[/green]")
                        console.print(f"[dim]목표: {short}[/dim]")
                        console.print()
                        goal = paper_goal
                        layout2 = make_layout()
                        layout2["header"].update(render_header(short, 0, max_iter, "idle"))
                        layout2["worker"].update(render_worker_panel(deque(), 0, "idle", [], False))
                        layout2["evaluator"].update(render_evaluator_panel([], 0, "idle", False))
                        layout2["cmd_bar"].update(render_cmd_bar(deque(), deque(), "idle", "idle"))
                        live2 = Live(layout2, refresh_per_second=8, screen=False)
                        outcome = run_agent_loop(
                            goal, workdir, args.worker_model, args.eval_model,
                            max_iter, layout2, live2,
                            mode=current_mode, eval_every=eval_every,
                        )
                        if outcome == 'interrupted':
                            console.print("\n[yellow]⚠  중단됨. REPL로 돌아갑니다.[/yellow]")
                        elif outcome == 'max':
                            console.print(f"[red]{max_iter}번 반복 후에도 완료되지 않았습니다.[/red]")
                        if outcome != 'interrupted':
                            console.print("[dim]다음 명령을 입력하세요. /exit 로 종료.[/dim]")

            elif cmd_name == 'mcp':
                sub_cmd, _, sub_arg = (cmd_arg or "").partition(" ")
                sub_arg = sub_arg.strip()

                if sub_cmd == "list" or not sub_cmd:
                    if not _MCP_REGISTRY:
                        console.print("[yellow]연결된 MCP 서버 없음[/yellow]")
                    for sname, client in _MCP_REGISTRY.items():
                        console.print(f"  [green]●[/green] [cyan]{sname}[/cyan]  port={client.port}  툴 {len(client.tools)}개")
                        for t in client.tools:
                            console.print(f"      [dim]{t['name']}[/dim]")

                elif sub_cmd == "install":
                    if not sub_arg:
                        console.print("[red]사용법: /mcp install <npm패키지>  예) /mcp install @playwright/mcp[/red]")
                    else:
                        pkg = sub_arg.strip()
                        console.print(f"[cyan]설치 중: {pkg}[/cyan]")
                        r = subprocess.run(
                            ["npm", "install", "-g", pkg],
                            capture_output=True, text=True
                        )
                        if r.returncode != 0:
                            console.print(f"[red]설치 실패:[/red]\n{r.stderr[:400]}")
                        else:
                            console.print(f"[green]✓ 설치 완료[/green]")
                            # 서버 이름 추론: @scope/name → name, name → name
                            sname = pkg.split("/")[-1].replace("-mcp", "").replace("server-", "")
                            cmd_list = ["npx", pkg, "--headless"] if "playwright" in pkg else ["npx", pkg]
                            # mcp.json 업데이트
                            cfg_path = Path.home() / ".agentforge" / "mcp.json"
                            try:
                                cfg = json.loads(cfg_path.read_text()) if cfg_path.exists() else {"servers": {}}
                            except Exception:
                                cfg = {"servers": {}}
                            cfg.setdefault("servers", {})[sname] = {"command": cmd_list}
                            cfg_path.write_text(json.dumps(cfg, indent=2, ensure_ascii=False))
                            console.print(f"[dim]~/.agentforge/mcp.json 에 '{sname}' 등록됨[/dim]")
                            # 즉시 연결 시도
                            client = _MCPClient(sname, cmd_list)
                            if client.start():
                                _MCP_REGISTRY[sname] = client
                                tool_names = [t["name"] for t in client.tools]
                                console.print(f"[green]✓ 연결됨 — 툴 {len(tool_names)}개: {', '.join(tool_names[:5])}[/green]")
                            else:
                                console.print(f"[yellow]설치됐지만 서버 시작 실패. agentforge 재시작 시 자동 연결됩니다.[/yellow]")

                elif sub_cmd == "remove":
                    if not sub_arg:
                        console.print("[red]사용법: /mcp remove <서버이름>[/red]")
                    else:
                        sname = sub_arg.strip()
                        if sname in _MCP_REGISTRY:
                            _MCP_REGISTRY[sname].stop()
                            del _MCP_REGISTRY[sname]
                        cfg_path = Path.home() / ".agentforge" / "mcp.json"
                        if cfg_path.exists():
                            try:
                                cfg = json.loads(cfg_path.read_text())
                                cfg.get("servers", {}).pop(sname, None)
                                cfg_path.write_text(json.dumps(cfg, indent=2, ensure_ascii=False))
                            except Exception:
                                pass
                        console.print(f"[cyan]{sname} 제거됨[/cyan]")
                else:
                    console.print("[red]사용법: /mcp list | /mcp install <pkg> | /mcp remove <name>[/red]")

            elif cmd_name == 'help':
                for cmd, desc in SLASH_COMMANDS:
                    console.print(f"  [cyan]{cmd:<30}[/cyan] {desc}")

            else:
                console.print(f"[red]알 수 없는 커맨드: /{cmd_name}[/red]")
                console.print("[dim]/help 로 커맨드 목록을 확인하세요.[/dim]")

        else:
            # 일반 텍스트 → 바로 Worker에게 목표로 전달
            goal = raw
            if current_mode == "dual":
                task_a, task_b = split_goal_to_tasks(goal, args.eval_model)
                layout2 = make_dual_layout()
                layout2["header"].update(render_header(goal, 0, max_iter, "idle"))
                layout2["summary_bar"].update(render_summary_bar(task_a, task_b, "idle", "idle"))
                layout2["worker1"].update(render_worker_panel(deque(), 0, "idle", [], False, label="WORKER 1"))
                layout2["worker2"].update(render_worker_panel(deque(), 0, "idle", [], False, label="WORKER 2"))
                layout2["evaluator"].update(render_dual_evaluator_panel([], [], 0, "idle", False, False))
                layout2["cmd_bar"].update(render_cmd_bar(deque(), deque(), "idle", "idle"))
                live2 = Live(layout2, refresh_per_second=8, screen=False)
                outcome = run_dual_agent_loop(
                    goal, task_a, task_b, workdir,
                    args.worker_model, args.eval_model,
                    max_iter, layout2, live2,
                    mode=current_mode, eval_every=eval_every,
                    session_context=_session_summaries if _session_summaries else None,
                )
            else:
                layout2 = make_layout()
                layout2["header"].update(render_header(goal, 0, max_iter, "idle"))
                layout2["worker"].update(render_worker_panel(deque(), 0, "idle", [], False))
                layout2["evaluator"].update(render_evaluator_panel([], 0, "idle", False))
                layout2["cmd_bar"].update(render_cmd_bar(deque(), deque(), "idle", "idle"))
                live2 = Live(layout2, refresh_per_second=8, screen=False)
                outcome = run_agent_loop(
                    goal, workdir, args.worker_model, args.eval_model,
                    max_iter, layout2, live2,
                    mode=current_mode, eval_every=eval_every,
                    session_context=_session_summaries if _session_summaries else None,
                )
            # 완료된 세션 요약을 다음 목표를 위해 저장
            if outcome != 'interrupted' and _last_session:
                sess = _last_session
                real_history = [h for h in sess.get("history", [])
                                if h.get("type") != "compressed_summary"]
                last_fb = next(
                    (h.get("feedback", "") for h in reversed(real_history)
                     if h.get("decision") in ("IMPROVE", "REDIRECT", "DONE")),
                    ""
                )
                _session_summaries.append({
                    "goal": sess.get("goal", goal),
                    "outcome": outcome,
                    "iter_count": len(real_history),
                    "last_feedback": last_fb,
                })
            if outcome == 'interrupted':
                console.print("\n[yellow]⚠  중단됨. REPL로 돌아갑니다.[/yellow]")
            elif outcome == 'max':
                console.print(f"[red]{max_iter}번 반복 후에도 완료되지 않았습니다.[/red]")
            if outcome != 'interrupted':
                console.print("[dim]다음 명령을 입력하세요. /exit 로 종료.[/dim]")


if __name__ == "__main__":
    main()
