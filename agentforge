                        except Exception:
                            lines.append(f"  {col} [{dtype}, {null_pct:.1f}% null]")
                lines += ["", "── Feature Engineering Suggestions ──"]
                date_cols = [c for c in df.columns
                             if any(kw in c.lower() for kw in ('date','time','dt','year','month','hour'))]
